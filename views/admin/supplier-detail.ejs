<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Supplier Details</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/admin/users">
                <i class="bi bi-people"></i>
                <span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers" class="active">
                <i class="bi bi-truck"></i>
                <span class="menu-text">Supplier Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/products">
                <i class="bi bi-box-seam"></i>
                <span class="menu-text">Product Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/orders">
                <i class="bi bi-cart-check"></i>
                <span class="menu-text">Order Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/disputes">
                <i class="bi bi-exclamation-triangle"></i>
                <span class="menu-text">Dispute Center</span>
              </a>
            </li>
            <li>
              <a href="/admin/settings">
                <i class="bi bi-gear"></i>
                <span class="menu-text">System Settings</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="sidebar-footer">
          <p>AdminPanel v1.0</p>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="page-title">Supplier Details</h1>

          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li><a class="dropdown-item" href="/admin/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                <li><a class="dropdown-item" href="/admin/settings"><i class="bi bi-gear me-2"></i>System Settings</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item text-danger" href="/company/login"><i class="bi bi-box-arrow-right me-2"></i>Sign Out</a></li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper">

          <!-- Back Button -->
          <a href="/admin/suppliers" class="back-link">
            <i class="bi bi-arrow-left"></i>
            Back to Suppliers
          </a>

          <!-- Loading State -->
          <div id="pageLoading" class="tab-loading">
            <i class="bi bi-arrow-repeat"></i>
            <p>Loading supplier details...</p>
          </div>

          <!-- Supplier Hero Card -->
          <div id="supplierHero" class="supplier-hero" style="display:none;">
            <div class="hero-avatar" id="heroAvatar"></div>
            <div class="hero-info">
              <h2 id="heroName"></h2>
              <p id="heroType"></p>
              <div class="hero-badges">
                <span class="hero-badge" id="heroBizType"></span>
                <span class="hero-badge verified" id="heroVerified"></span>
              </div>
            </div>
            <div class="hero-stats">
              <div class="hero-stat">
                <span class="value" id="heroProducts"></span>
                <span class="label">Products</span>
              </div>
              <div class="hero-stat-divider"></div>
              <div class="hero-stat">
                <span class="value" id="heroOrders"></span>
                <span class="label">Orders</span>
              </div>
              <div class="hero-stat-divider"></div>
              <div class="hero-stat">
                <span class="value" id="heroEarnings"></span>
                <span class="label">Earnings</span>
              </div>
            </div>
          </div>

          <!-- Tab Panel -->
          <div id="detailTabs" class="detail-tabs" style="display:none;">
            <ul class="nav nav-tabs" id="supplierTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button
                  class="nav-link active"
                  id="profile-tab"
                  data-bs-toggle="tab"
                  data-bs-target="#profile-content"
                  type="button"
                  role="tab"
                >
                  <i class="bi bi-person-lines-fill"></i>
                  Profile
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button
                  class="nav-link"
                  id="products-tab"
                  data-bs-toggle="tab"
                  data-bs-target="#products-content"
                  type="button"
                  role="tab"
                >
                  <i class="bi bi-box-seam"></i>
                  Products
                  <span class="badge bg-primary ms-1" id="productsCount" style="font-size:10px;">0</span>
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button
                  class="nav-link"
                  id="orders-tab"
                  data-bs-toggle="tab"
                  data-bs-target="#orders-content"
                  type="button"
                  role="tab"
                >
                  <i class="bi bi-cart-check"></i>
                  Orders
                  <span class="badge bg-primary ms-1" id="ordersCount" style="font-size:10px;">0</span>
                </button>
              </li>
            </ul>

            <div class="tab-content" id="supplierTabContent">

              <!-- ====== PROFILE TAB ====== -->
              <div class="tab-pane fade show active" id="profile-content" role="tabpanel">
                <div class="row g-4">
                  <div class="col-md-7">
                    <div class="info-section-title"><i class="bi bi-info-circle me-1"></i>Business Information</div>
                    <div class="info-grid">
                      <div class="info-item">
                        <div class="info-label"><i class="bi bi-building"></i> Business Name</div>
                        <div class="info-value" id="profBusinessName">—</div>
                      </div>
                      <div class="info-item">
                        <div class="info-label"><i class="bi bi-person"></i> Owner</div>
                        <div class="info-value" id="profOwnerName">—</div>
                      </div>
                      <div class="info-item">
                        <div class="info-label"><i class="bi bi-envelope"></i> Email</div>
                        <div class="info-value" id="profEmail">—</div>
                      </div>
                      <div class="info-item">
                        <div class="info-label"><i class="bi bi-telephone"></i> Mobile</div>
                        <div class="info-value" id="profMobile">—</div>
                      </div>
                      <div class="info-item">
                        <div class="info-label"><i class="bi bi-briefcase"></i> Business Type</div>
                        <div class="info-value" id="profBizType">—</div>
                      </div>
                      <div class="info-item">
                        <div class="info-label"><i class="bi bi-patch-check"></i> Verification</div>
                        <div class="info-value" id="profVerification">—</div>
                      </div>
                      <div class="info-item full-width">
                        <div class="info-label"><i class="bi bi-file-text"></i> Registration</div>
                        <div class="info-value" id="profRegistration">—</div>
                      </div>
                      <div class="info-item full-width">
                        <div class="info-label"><i class="bi bi-chat-left-text"></i> Description</div>
                        <div class="info-value" id="profDescription" style="font-size:16px;font-weight:400;color:#374151;line-height:1.6;">—</div>
                      </div>
                    </div>
                  </div>

                  <div class="col-md-5">
                    <div class="info-section-title"><i class="bi bi-geo-alt me-1"></i>Address</div>
                    <div class="address-block mb-4">
                      <i class="bi bi-geo-alt-fill"></i>
                      <div class="address-text" id="profAddress">
                        <strong>Business Address</strong>
                        Loading...
                      </div>
                    </div>

                    <div class="info-section-title"><i class="bi bi-bar-chart me-1"></i>Quick Stats</div>
                    <div class="info-grid" style="grid-template-columns:1fr 1fr 1fr;">
                      <div class="info-item" style="text-align:center;">
                        <div class="info-label" style="justify-content:center;">Products</div>
                        <div class="info-value" id="statProducts" style="font-size:22px;color:var(--primary-color);">—</div>
                      </div>
                      <div class="info-item" style="text-align:center;">
                        <div class="info-label" style="justify-content:center;">Orders</div>
                        <div class="info-value" id="statOrders" style="font-size:22px;color:var(--primary-color);">—</div>
                      </div>
                      <div class="info-item" style="text-align:center;">
                        <div class="info-label" style="justify-content:center;">Earnings</div>
                        <div class="info-value" id="statEarnings" style="font-size:16px;color:#059669;">—</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- ====== PRODUCTS TAB ====== -->
              <div class="tab-pane fade" id="products-content" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <h5 class="fw-bold mb-1">Product Catalogue</h5>
                    <p class="text-muted mb-0" style="font-size:13.5px;">All products supplied by this vendor</p>
                  </div>
                </div>
                <div class="products-grid" id="productsGrid">
                  <!-- populated by JS -->
                </div>
              </div>

              <!-- ====== ORDERS TAB ====== -->
              <div class="tab-pane fade" id="orders-content" role="tabpanel">
                <div class="earnings-summary">
                  <div>
                    <div class="earnings-label">Total Earnings</div>
                    <div class="earnings-value" id="totalEarnings">—</div>
                  </div>
                  <div class="earnings-icon">
                    <i class="bi bi-currency-rupee"></i>
                  </div>
                </div>

                <div class="orders-table-wrap">
                  <table class="orders-table">
                    <thead>
                      <tr>
                        <th>Order ID</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                      </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                      <!-- populated by JS -->
                    </tbody>
                  </table>
                </div>
              </div>

            </div>
          </div>

        </div>
      </main>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sidebar toggle (same as existing main.js logic) -->
    <script src="/assets/js/main.js"></script>
  </body>
</html>
