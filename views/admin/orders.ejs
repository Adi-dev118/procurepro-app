<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Order Management</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="../assets/css/style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/admin/users">
                <i class="bi bi-people"></i>
                <span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers">
                <i class="bi bi-truck"></i>
                <span class="menu-text">Supplier Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/products">
                <i class="bi bi-box-seam"></i>
                <span class="menu-text">Product Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/orders" class="active">
                <i class="bi bi-cart-check"></i>
                <span class="menu-text">Order Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/disputes">
                <i class="bi bi-exclamation-triangle"></i>
                <span class="menu-text">Dispute Center</span>
              </a>
            </li>
            <li>
              <a href="/admin/settings">
                <i class="bi bi-gear"></i>
                <span class="menu-text">System Settings</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="sidebar-footer">
          <p>AdminPanel v1.0</p>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="page-title">Order Management</h1>

          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/profile">
                    <i class="bi bi-person me-2"></i>My Profile
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/settings">
                    <i class="bi bi-gear me-2"></i>System Settings
                  </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item text-danger" href="/company/login" id="signoutButton">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper orders-page">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title">Order Management</h1>
            <button class="btn btn-primary">
              <i class="bi bi-plus-circle me-2"></i>
              Create Order
            </button>
          </div>

          <!-- Order Stats -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Total Orders</h6>
                      <h3 class="mb-0"><%= totalOrders %></h3>
                    </div>
                    <div class="stat-icon bg-primary">
                      <i class="bi bi-cart"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 8% from last week
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Pending Orders</h6>
                      <h3 class="mb-0"><%= pendingOrders %></h3>
                    </div>
                    <div class="stat-icon bg-warning">
                      <i class="bi bi-clock-history"></i>
                    </div>
                  </div>
                  <p class="text-danger mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 5 from yesterday
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Processing</h6>
                      <h3 class="mb-0"><%= processingOrders %></h3>
                    </div>
                    <div class="stat-icon bg-info">
                      <i class="bi bi-gear"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-down"></i> 12 from yesterday
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Completed</h6>
                      <h3 class="mb-0"><%= completedOrders %></h3>
                    </div>
                    <div class="stat-icon bg-success">
                      <i class="bi bi-check-circle"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 24 from yesterday
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Order Table -->
          <div class="table-container">
            <div class="table-header">
              <div class="table-actions">
                <div class="input-group" style="width: 300px">
                  <input type="text" class="form-control" placeholder="Search orders..." />
                  <button class="btn btn-outline-secondary search-btn" type="button">
                    <i class="bi bi-search"></i>
                  </button>
                </div>

                <div class="btn-group">
                  <div class="btn-group">
                    <button
                      class="btn btn-outline-secondary dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                    >
                      <i class="bi bi-filter me-1"></i>Order Status
                    </button>
                    <ul class="dropdown-menu">
                      <li>
                        <a class="dropdown-item status-filter" href="#" data-status="delivered"
                          >Delivered</a
                        >
                      </li>
                      <li>
                        <a class="dropdown-item status-filter" href="#" data-status="processing"
                          >Processing</a
                        >
                      </li>
                      <li>
                        <a class="dropdown-item status-filter" href="#" data-status="pending"
                          >Pending</a
                        >
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="btn-group">
                  <div class="btn-group">
                    <button
                      class="btn btn-outline-secondary dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                    >
                      <i class="bi bi-filter me-1"></i>Payment Status
                    </button>
                    <ul class="dropdown-menu">
                      <li>
                        <a class="dropdown-item payment-filter" href="#" data-payment="paid"
                          >Paid</a
                        >
                      </li>
                      <li>
                        <a class="dropdown-item payment-filter" href="#" data-payment="pending"
                          >Pending</a
                        >
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="btn-group">
                  <div class="btn-group">
                    <button
                      class="btn btn-outline-secondary dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                    >
                      <i class="bi bi-filter me-1"></i>Date Range
                    </button>
                    <ul class="dropdown-menu">
                      <li>
                        <a class="dropdown-item status-filter" href="#" data-range="today"
                          >Today</a
                        >
                      </li>
                      <li>
                        <a class="dropdown-item status-filter" href="#" data-range="7days"
                          >Last 7 days</a
                        >
                      </li>
                      <li>
                        <a class="dropdown-item status-filter" href="#" data-range="30days"
                          >Last 30 days</a
                        >
                      </li>
                      <li>
                        <a class="dropdown-item date-filter" href="#" data-range="month"
                          >Last month</a
                        >
                      </li>
                    </ul>
                  </div>
                </div>
                <button class="btn btn-outline-danger clear-filters">Clear Filters</button>
                <button class="btn btn-outline-secondary">
                  <i class="bi bi-download me-2"></i>
                  Export
                </button>
              </div>
            </div>

            <div class="table-responsive">
              <table class="table table-hover" data-sortable="true">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Type</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="order-body"></tbody>
              </table>
              <div class="pagination-container">
                <div class="pagination-info"></div>
                <nav>
                  <ul class="pagination" id="pagination"></ul>
                </nav>
              </div>
            </div>
          </div>

          <!-- Order Status Overview -->
          <div class="row mt-5">
            <div class="col-lg-8">
              <div class="chart-container">
                <div class="chart-header">
                  <h3 class="chart-title">Order Status Overview</h3>
                  <div class="dropdown">
                    <button
                      class="btn btn-outline-secondary btn-sm dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                    >
                      Last 30 days
                    </button>
                    <ul class="dropdown-menu">
                      <li><a class="dropdown-item" href="#">Last 7 days</a></li>
                      <li>
                        <a class="dropdown-item" href="#">Last 30 days</a>
                      </li>
                      <li>
                        <a class="dropdown-item" href="#">Last 90 days</a>
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="chart-placeholder">
                  <i class="bi bi-pie-chart me-2"></i>
                  Order Status Distribution Chart (Placeholder)
                </div>
              </div>
            </div>

            <div class="col-lg-4">
              <div class="chart-container">
                <div class="chart-header">
                  <h3 class="chart-title">Revenue by Status</h3>
                </div>
                <div class="chart-placeholder">
                  <i class="bi bi-bar-chart me-2"></i>
                  Revenue by Status Chart (Placeholder)
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Order Activity -->
          <div class="mt-5">
            <h3 class="section-title">Recent Order Activity</h3>

            <div class="row">
              <% activities.forEach(activity => { %>
              <div class="col-md-4">
                <div class="activity-card">
                  <div class="activity-icon bg-<%= activity.color %>">
                    <i class="bi <%= activity.icon %>"></i>
                  </div>

                  <div class="activity-content">
                    <h5><%= activity.title %></h5>
                    <p class="text-muted"><%= activity.message %></p>
                    <span class="text-muted small"><%= activity.date %></span>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
        <!-- end content-wrapper -->
      </main>
    </div>
    <!-- end dashboard-container -->

    <!-- View Order Modal -->
    <div
      class="modal fade"
      id="viewOrderModal"
      tabindex="-1"
      aria-labelledby="viewOrderModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="viewOrderModalLabel">Order Details - #ORD-7842</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <div class="row mb-4">
              <div class="col-md-6">
                <h6>Customer Information</h6>
                <div class="card p-3">
                  <p class="mb-1"><strong>John Doe</strong></p>
                  <p class="mb-1">john.doe@example.com</p>
                  <p class="mb-1">+1 (555) 123-4567</p>
                  <p class="mb-0">123 Main St, Apt 4B<br />New York, NY 10001</p>
                </div>
              </div>
              <div class="col-md-6">
                <h6>Order Information</h6>
                <div class="card p-3">
                  <div class="row">
                    <div class="col-6">
                      <p class="mb-1"><strong>Order Date:</strong></p>
                      <p class="mb-1"><strong>Status:</strong></p>
                      <p class="mb-1"><strong>Payment:</strong></p>
                    </div>
                    <div class="col-6">
                      <p class="mb-1">Nov 5, 2023 10:30 AM</p>
                      <p class="mb-1">
                        <span class="badge bg-success">Completed</span>
                      </p>
                      <p class="mb-1">
                        <span class="badge bg-success">Paid</span>
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <h6>Order Items</h6>
            <div class="table-responsive mb-4">
              <table class="table">
                <thead>
                  <tr>
                    <th>Product</th>
                    <th>SKU</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Wireless Bluetooth Headphones</td>
                    <td>SKU-001</td>
                    <td>$129.99</td>
                    <td>1</td>
                    <td>$129.99</td>
                  </tr>
                  <tr>
                    <td>Smart Watch Pro</td>
                    <td>SKU-002</td>
                    <td>$249.99</td>
                    <td>1</td>
                    <td>$249.99</td>
                  </tr>
                  <tr>
                    <td>Modern Table Lamp</td>
                    <td>SKU-005</td>
                    <td>$79.99</td>
                    <td>1</td>
                    <td>$79.99</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="row">
              <div class="col-md-6 offset-md-6">
                <div class="card">
                  <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                      <span>Subtotal:</span>
                      <span>$459.97</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Shipping:</span>
                      <span>$10.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Tax:</span>
                      <span>$36.80</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                      <strong>Total:</strong>
                      <strong>$506.77</strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-4">
              <h6>Shipping Information</h6>
              <div class="card p-3">
                <p class="mb-1"><strong>Shipping Method:</strong> Standard Shipping</p>
                <p class="mb-1"><strong>Tracking Number:</strong> TRK-789456123</p>
                <p class="mb-0">
                  <strong>Shipping Address:</strong> 123 Main St, Apt 4B, New York, NY 10001
                </p>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary">Print Invoice</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="../assets/js/main.js"></script>
    <script type="module" src="../assets/js/admin/order/order.main.js"></script>
  </body>
</html>
