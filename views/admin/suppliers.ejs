<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Supplier Management</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/assets/css/style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/admin/users">
                <i class="bi bi-people"></i>
                <span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers" class="active">
                <i class="bi bi-truck"></i>
                <span class="menu-text">Supplier Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/products">
                <i class="bi bi-box-seam"></i>
                <span class="menu-text">Product Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/orders">
                <i class="bi bi-cart-check"></i>
                <span class="menu-text">Order Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/disputes">
                <i class="bi bi-exclamation-triangle"></i>
                <span class="menu-text">Dispute Center</span>
              </a>
            </li>
            <li>
              <a href="/admin/settings">
                <i class="bi bi-gear"></i>
                <span class="menu-text">System Settings</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="sidebar-footer">
          <p>AdminPanel v1.0</p>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="page-title">Supplier Management</h1>

          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/profile">
                    <i class="bi bi-person me-2"></i>My Profile</a
                  >
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/settings">
                    <i class="bi bi-gear me-2"></i>System Settings</a
                  >
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item text-danger" href="/company/login" id="signoutButton">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out</a
                  >
                </li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper suppliers-page">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title">Supplier Management</h1>
            <button
              class="btn btn-primary"
              data-bs-toggle="modal"
              data-bs-target="#addSupplierModal"
            >
              <i class="bi bi-plus-circle me-2"></i>
              Add Supplier
            </button>
          </div>

          <!-- Supplier Stats -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Total Suppliers</h6>
                      <h3 class="mb-0"><%=stats.suppliers%></h3>
                    </div>
                    <div class="stat-icon bg-primary">
                      <i class="bi bi-building"></i>
                    </div>
                  </div>
                  <p class="text-danger mt-2 mb-0">
                    <i class="bi bi-arrow-down"></i> 2.1% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Active Suppliers</h6>
                      <h3 class="mb-0"><%=stats.activeSuppliers%></h3>
                    </div>
                    <div class="stat-icon bg-success">
                      <i class="bi bi-check-circle"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 4.2% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Pending Approval</h6>
                      <h3 class="mb-0"><%=stats.pendingSuppliers%></h3>
                    </div>
                    <div class="stat-icon bg-warning">
                      <i class="bi bi-clock-history"></i>
                    </div>
                  </div>
                  <p class="text-warning mt-2 mb-0"><i class="bi bi-clock"></i> Need review</p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Avg. Rating</h6>
                      <h3 class="mb-0"><%=stats.avgSupplierRating%> ★</h3>
                    </div>
                    <div class="stat-icon bg-info">
                      <i class="bi bi-star-fill"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 0.2 from last month
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Supplier Table -->
          <div class="table-container">
            <div class="table-header">
              <div class="table-actions">
                <div class="input-group" style="width: 300px">
                  <input type="text" class="form-control" placeholder="Search suppliers..." data-type="suppliers" name="search"/>
                  <button class="btn btn-outline-secondary search-btn" type="button">
                    <i class="bi bi-search"></i>
                  </button>
                </div>
                <div class="btn-group">
                  <button
                    class="btn btn-outline-secondary dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                  >
                    <i class="bi bi-filter me-1"></i> Status
                  </button>
                  <ul class="dropdown-menu">
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="approved"
                        >Active</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="suspended"
                        >Suspended</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="pending"
                        >Pending</a
                      >
                    </li>
                  </ul>
                </div>

                <button class="btn btn-outline-secondary">
                  <i class="bi bi-download me-2"></i>
                  Export
                </button>
                <button class="btn btn-outline-danger clear-filters">Clear Filters
                </button>
              </div>
            </div>

            <div class="table-responsive">
              <table class="table table-hover" data-sortable="true">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Supplier</th>
                    <th>Contact</th>
                    <th>Products</th>
                    <th>Rating</th>
                    <th>Commission</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="supplier-body"></tbody>
              </table>

              <div class="pagination-container">
                <div class="pagination-info"></div>
                <nav>
                  <ul class="pagination" id="supplier-pagination"></ul>
                </nav>
              </div>
            </div>
          </div>

          <!-- Performance Overview -->
          <div class="row mt-5">
            <div class="col-lg-8">
              <div class="chart-container">
                <div class="chart-header">
                  <h3 class="chart-title">Supplier Performance Overview</h3>
                  <div class="dropdown">
                    <button
                      class="btn btn-outline-secondary btn-sm dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                    >
                      Last 30 days
                    </button>
                    <ul class="dropdown-menu">
                      <li><a class="dropdown-item" href="#">Last 7 days</a></li>
                      <li><a class="dropdown-item" href="#">Last 30 days</a></li>
                      <li><a class="dropdown-item" href="#">Last 90 days</a></li>
                    </ul>
                  </div>
                </div>
                <div class="chart-placeholder">
                  <i class="bi bi-bar-chart me-2"></i>
                  Supplier Performance Chart (Placeholder)
                </div>
              </div>
            </div>

            <div class="col-lg-4">
              <div class="chart-container">
                <div class="chart-header">
                  <h3 class="chart-title">Top Suppliers by Revenue</h3>
                </div>
                <div class="chart-placeholder">
                  <i class="bi bi-trophy me-2"></i>
                  Top Suppliers Chart (Placeholder)
                </div>
              </div>
            </div>
          </div>

          <!-- Flagged Listings Section -->
          <div class="mt-5">
            <h3 class="section-title">Flagged/Inappropriate Listings</h3>
            <div class="table-container">
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Listing</th>
                      <th>Supplier</th>
                      <th>Flagged Reason</th>
                      <th>Reported By</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Premium Headphones</td>
                      <td>TechGadgets Ltd</td>
                      <td>Misleading description</td>
                      <td>Customer #1234</td>
                      <td><span class="status-badge pending">Under Review</span></td>
                      <td>
                        <div class="action-buttons">
                          <button class="btn btn-info btn-sm me-1">Review</button>
                          <button class="btn btn-danger btn-sm">Remove</button>
                        </div>
                      </td>
                    </tr>
                    <tr>
                      <td>Designer Handbag</td>
                      <td>Sarah Johnson</td>
                      <td>Counterfeit item</td>
                      <td>Customer #5678</td>
                      <td><span class="status-badge suspended">Removed</span></td>
                      <td>
                        <div class="action-buttons">
                          <button class="btn btn-warning btn-sm">Restore</button>
                        </div>
                      </td>
                    </tr>
                    <tr>
                      <td>Smart Watch</td>
                      <td>Global Supplies Inc.</td>
                      <td>Incorrect specifications</td>
                      <td>Customer #9012</td>
                      <td><span class="status-badge pending">Under Review</span></td>
                      <td>
                        <div class="action-buttons">
                          <button class="btn btn-info btn-sm me-1">Review</button>
                          <button class="btn btn-danger btn-sm">Remove</button>
                        </div>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Add Supplier Modal -->
    <div
      class="modal fade"
      id="addSupplierModal"
      tabindex="-1"
      aria-labelledby="addSupplierModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addSupplierModalLabel">Add New Supplier</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="addSupplierForm">
              <div class="mb-3">
                <label for="supplierName" class="form-label">Company Name</label>
                <input type="text" class="form-control" id="supplierName" required />
              </div>

              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="contactPerson" class="form-label">Contact Person</label>
                    <input type="text" class="form-control" id="contactPerson" required />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="contactEmail" class="form-label">Contact Email</label>
                    <input type="email" class="form-control" id="contactEmail" required />
                  </div>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="phoneNumber" class="form-label">Phone Number</label>
                    <input type="tel" class="form-control" id="phoneNumber" />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="website" class="form-label">Website</label>
                    <input type="url" class="form-control" id="website" />
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label for="businessType" class="form-label">Business Type</label>
                <select class="form-select" id="businessType" required>
                  <option value="">Select Type</option>
                  <option value="manufacturer">Manufacturer</option>
                  <option value="wholesaler">Wholesaler</option>
                  <option value="retailer">Retailer</option>
                  <option value="dropshipper">Dropshipper</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="commissionRate" class="form-label">Commission Rate (%)</label>
                <input
                  type="number"
                  class="form-control"
                  id="commissionRate"
                  min="1"
                  max="50"
                  step="0.5"
                  value="15"
                />
              </div>

              <div class="mb-3">
                <label for="supplierStatus" class="form-label">Account Status</label>
                <select class="form-select" id="supplierStatus">
                  <option value="active">Active</option>
                  <option value="pending">Pending Approval</option>
                  <option value="suspended">Suspended</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="businessAddress" class="form-label">Business Address</label>
                <textarea class="form-control" id="businessAddress" rows="3"></textarea>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" form="addSupplierForm" class="btn btn-primary">
              Add Supplier
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- View Supplier Modal -->
    <div
      class="modal fade"
      id="viewSupplierModal"
      tabindex="-1"
      aria-labelledby="viewSupplierModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="viewSupplierModalLabel">Supplier Details</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <div class="row">
              <div class="col-md-4 text-center">
                <div
                  class="user-avatar mx-auto mb-3"
                  style="width: 100px; height: 100px; font-size: 36px; background-color: #f72585"
                >
                  SJ
                </div>
                <h5 id="modalSupplierName"></h5>
                <p class="text-muted" id="modalSupplierType"></p>
                <span class="badge bg-warning">Supplier</span>
                <div class="mt-3">
                  <span class="text-warning">4.8 ★</span>
                  <p class="text-muted small">(128 reviews)</p>
                </div>
              </div>
              <div class="col-md-8">
                <div class="row mb-3">
                  <div class="col-6">
                    <label class="form-label text-muted">Email</label>
                    <p id="modalSupplierEmail"></p>
                  </div>
                  <div class="col-6">
                    <label class="form-label text-muted">Phone</label>
                    <p id="modalSupplierMobile"></p>
                  </div>
                </div>
                <div class="row mb-3">
                  <div class="col-6">
                    <label class="form-label text-muted">Registration Date</label>
                    <p id="modalSupplierDate"></p>
                  </div>
                  <div class="col-6">
                    <label class="form-label text-muted">Commission Rate</label>
                    <p><span class="badge bg-info" id="modalSupplierCommission"></span></p>
                  </div>
                </div>
                <div class="row mb-3">
                  <div class="col-6">
                    <label class="form-label text-muted">Total Products</label>
                    <p id="modalSupplierProducts"></p>
                  </div>
                  <div class="col-6">
                    <label class="form-label text-muted">Total Sales</label>
                    <p id="modalSupplierSales"></p>
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label text-muted">Business Address</label>
                  <p id="modalSupplierAddress"></p>
                </div>
                <div class="mb-3">
                  <label class="form-label text-muted">Business Description</label>
                  <p id="modalSupplierDescription"></p>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary">Edit Supplier</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="../assets/js/main.js"></script>
    <script type="module" src="../assets/js/admin/suppliers/supplier.main.js"></script>
    <script>
      document.querySelectorAll('.viewSupplier').forEach((btn) => {
        btn.addEventListener('click', function () {
          const name = this.dataset.name;
          const email = this.dataset.email;
          const products = this.dataset.products;
          const commission = this.dataset.commission;
          const type = this.dataset.type;
          const mobile = this.dataset.mobile;
          const date = this.dataset.date;
          const sales = this.dataset.sales;
          const description = this.dataset.description;
          const address = this.dataset.address;

          document.getElementById('modalSupplierName').innerText = name;
          document.getElementById('modalSupplierEmail').innerText = email;
          document.getElementById('modalSupplierProducts').innerText = products;
          document.getElementById('modalSupplierCommission').innerText = commission + '%';
          document.getElementById('modalSupplierType').innerText = type;
          document.getElementById('modalSupplierMobile').innerText = mobile;
          document.getElementById('modalSupplierDate').innerText = date;
          document.getElementById('modalSupplierSales').innerText = '$ ' + sales;
          document.getElementById('modalSupplierDescription').innerText = description;
          document.getElementById('modalSupplierAddress').innerText = address;
        });
      });
    </script>
  </body>
</html>
