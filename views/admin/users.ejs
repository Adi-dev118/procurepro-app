<!-- <!DOCTYPE html> -->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - User Management</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="../assets/css/style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/admin/users" class="active">
                <i class="bi bi-people"></i>
                <span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers">
                <i class="bi bi-truck"></i>
                <span class="menu-text">Supplier Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/products">
                <i class="bi bi-box-seam"></i>
                <span class="menu-text">Product Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/orders">
                <i class="bi bi-cart-check"></i>
                <span class="menu-text">Order Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/disputes">
                <i class="bi bi-exclamation-triangle"></i>
                <span class="menu-text">Dispute Center</span>
              </a>
            </li>
            <li>
              <a href="/admin/settings">
                <i class="bi bi-gear"></i>
                <span class="menu-text">System Settings</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="sidebar-footer">
          <p>AdminPanel v1.0</p>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="page-title">User Management</h1>

          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/profile">
                    <i class="bi bi-person me-2"></i>My Profile</a
                  >
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/settings">
                    <i class="bi bi-gear me-2"></i>System Settings</a
                  >
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item text-danger" href="/company/login" id="signoutButton">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out</a
                  >
                </li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper users-page">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title">User Management</h1>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
              <i class="bi bi-plus-circle me-2"></i>
              Add New User
            </button>
          </div>

          <!-- User Stats -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Total Users</h6>
                      <h3 class="mb-0"><%=stats.totalUsers%></h3>
                    </div>
                    <div class="stat-icon bg-primary">
                      <i class="bi bi-people"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 5.2% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Active Buyers</h6>
                      <h3 class="mb-0"><%=stats.totalBuyers%></h3>
                    </div>
                    <div class="stat-icon bg-success">
                      <i class="bi bi-person-check"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 3.7% from last week
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Active Suppliers</h6>
                      <h3 class="mb-0"><%=stats.activeSuppliers%></h3>
                    </div>
                    <div class="stat-icon bg-warning">
                      <i class="bi bi-building"></i>
                    </div>
                  </div>
                  <p class="text-danger mt-2 mb-0">
                    <i class="bi bi-arrow-down"></i> 2.1% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Pending Approval</h6>
                      <h3 class="mb-0"><%=stats.pendingUsers%></h3>
                    </div>
                    <div class="stat-icon bg-info">
                      <i class="bi bi-clock-history"></i>
                    </div>
                  </div>
                  <p class="text-warning mt-2 mb-0"><i class="bi bi-clock"></i> Need review</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Tabs -->
          <ul class="nav nav-tabs" id="userTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button
                class="nav-link active"
                id="all-users-tab"
                data-bs-toggle="tab"
                data-bs-target="#all-users"
                type="button"
              >
                All Users
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="buyers-tab"
                data-bs-toggle="tab"
                data-bs-target="#buyers"
                type="button"
              >
                Buyers
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="suppliers-tab"
                data-bs-toggle="tab"
                data-bs-target="#suppliers"
                type="button"
              >
                Suppliers
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="pending-tab"
                data-bs-toggle="tab"
                data-bs-target="#pending"
                type="button"
              >
                Pending Approval
              </button>
            </li>
          </ul>

          <!-- Tab Content -->
          <div class="tab-content" id="userTabsContent">
            <!-- All Users Tab -->
            <div class="tab-pane fade show active" id="all-users" role="tabpanel">
              <div class="table-container mt-3">
                <div class="table-header">
                  <div class="table-actions">
                    <div>
                      <div class="input-group" style="width: 300px">
                        <input
                          type="text"
                          name="search"
                          class="form-control"
                          placeholder="Search users..."
                          data-type="users"
                        />
                        <button class="btn btn-outline-secondary search-btn" type="button">
                          <i class="bi bi-search"></i>
                        </button>
                      </div>
                    </div>
                    <div class="btn-group">
                      <button
                        class="btn btn-outline-secondary dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                      >
                        <i class="bi bi-filter me-1"></i> Status
                      </button>
                      <ul class="dropdown-menu">
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="active"
                            >Active</a
                          >
                        </li>
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="suspended"
                            >Suspended</a
                          >
                        </li>
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="pending"
                            >Pending</a
                          >
                        </li>
                      </ul>
                    </div>
                    <div class="btn-group">
                      <button
                        class="btn btn-outline-secondary dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                      >
                        <i class="bi bi-filter me-1"></i> Role
                      </button>
                      <ul class="dropdown-menu">
                        <li>
                          <a class="dropdown-item" href="#" data-role="buyer">Buyer</a>
                        </li>
                        <li>
                          <a class="dropdown-item" href="#" data-role="supplier">Supplier</a>
                        </li>
                      </ul>
                    </div>

                    <button class="btn btn-outline-secondary">
                      <i class="bi bi-download me-2"></i>
                      Export
                    </button>
                    <button class="btn btn-outline-danger clear-filters">Clear Filters</button>
                  </div>
                </div>

                <div class="table-responsive">
                  <table class="table table-hover" data-sortable="true">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Registration Date</th>
                        <th>Status</th>
                      </tr>
                    </thead>
                    <tbody></tbody>
                  </table>
                </div>

                <div class="pagination-container">
                  <div class="pagination-info-all-users"></div>
                  <nav>
                    <ul class="pagination" id="pagination"></ul>
                  </nav>
                </div>
              </div>
            </div>

            <!-- Buyers Tab -->

            <div class="tab-pane fade" id="buyers" role="tabpanel">
              <div class="table-container mt-3">
                <div class="table-header">
                  <div class="table-actions">
                    <div>
                      <div class="input-group" style="width: 300px">
                        <input
                          type="text"
                          name="search"
                          class="form-control"
                          placeholder="Search Buyers..."
                          data-type="buyers"
                        />
                        <button class="btn btn-outline-secondary search-btn" type="button">
                          <i class="bi bi-search"></i>
                        </button>
                      </div>
                    </div>
                    <div class="btn-group">
                      <button
                        class="btn btn-outline-secondary dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                      >
                        <i class="bi bi-filter me-1"></i> Status
                      </button>
                      <ul class="dropdown-menu">
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="active"
                            >Active</a
                          >
                        </li>
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="suspended"
                            >Suspended</a
                          >
                        </li>
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="pending"
                            >Pending</a
                          >
                        </li>
                      </ul>
                    </div>
                    <button class="btn btn-outline-secondary">
                      <i class="bi bi-download me-2"></i>
                      Export
                    </button>
                    <button class="btn btn-outline-danger clear-filters">Clear Filters</button>
                  </div>
                </div>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Orders</th>
                        <th>Total Spent</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="buyers-body"></tbody>
                  </table>
                </div>
                <div class="pagination-container">
                  <div class="pagination-info-buyers"></div>
                  <nav>
                    <ul class="pagination" id="buyers-pagination"></ul>
                  </nav>
                </div>
              </div>
            </div>

            <!-- Suppliers Tab -->
            <div class="tab-pane fade" id="suppliers" role="tabpanel">
              <div class="table-container mt-3">
                <div class="table-header">
                  <div class="table-actions">
                    <div>
                      <div class="input-group" style="width: 300px">
                        <input
                          type="text"
                          name="search"
                          class="form-control"
                          placeholder="Search Suppliers..."
                          data-type="suppliers"
                        />
                        <button class="btn btn-outline-secondary search-btn" type="button">
                          <i class="bi bi-search"></i>
                        </button>
                      </div>
                    </div>
                    <div class="btn-group">
                      <button
                        class="btn btn-outline-secondary dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                      >
                        <i class="bi bi-filter me-1"></i> Status
                      </button>
                      <ul class="dropdown-menu">
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="active"
                            >Active</a
                          >
                        </li>
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="suspended"
                            >Suspended</a
                          >
                        </li>
                        <li>
                          <a class="dropdown-item status-filter" href="#" data-status="pending"
                            >Pending</a
                          >
                        </li>
                      </ul>
                    </div>
                    <button class="btn btn-outline-secondary">
                      <i class="bi bi-download me-2"></i>
                      Export
                    </button>
                    <button class="btn btn-outline-danger clear-filters">Clear Filters</button>
                  </div>
                </div>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Company</th>
                        <th>Contact</th>
                        <th>Products</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="suppliers-body"></tbody>
                  </table>
                </div>
                <div class="pagination-container">
                  <div class="pagination-info-suppliers"></div>
                  <nav>
                    <ul class="pagination" id="suppliers-pagination"></ul>
                  </nav>
                </div>
              </div>
            </div>

            <!-- Pending Approval Tab -->
            <div class="tab-pane fade" id="pending" role="tabpanel">
              <div class="table-container mt-3">
                <div class="table-header">
                  <div class="table-actions">
                    <div>
                      <div class="input-group" style="width: 300px">
                        <input
                          type="text"
                          name="search"
                          class="form-control"
                          placeholder="Search Pending Users..."
                          data-type="pending"
                        />
                        <button class="btn btn-outline-secondary search-btn" type="button">
                          <i class="bi bi-search"></i>
                        </button>
                      </div>
                    </div>
                    <button class="btn btn-outline-secondary">
                      <i class="bi bi-download me-2"></i>
                      Export
                    </button>
                  </div>
                </div>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Name/Company</th>
                        <th>Type</th>
                        <th>Submitted</th>
                        <th>Documents</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="pending-body"></tbody>
                  </table>
                </div>
                <div class="pagination-container">
                  <div class="pagination-info-pending"></div>
                  <nav>
                    <ul class="pagination" id="pending-pagination"></ul>
                  </nav>
                </div>
              </div>
            </div>

            <!-- Suspended Tab -->
          </div>

          <!-- User Activity Logs -->
          <div class="mt-5">
            <h3 class="section-title">Recent User Activity Logs</h3>
            <div class="table-container">
              <div class="table-responsive">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Timestamp</th>
                      <th>User</th>
                      <th>IP Address</th>
                      <th>Activity</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <%activityLogs.forEach(activity => {%>
                    <tr>
                      <td>
                        <%= new Date(activity.timeStamp).toISOString().slice(0,19).replace('T',' ')%>
                      </td>
                      <td><%=activity.name%></td>
                      <td><%=activity.address%></td>
                      <td><%=activity.log%></td>
                      <td>
                        <%if(activity.status==="Success") {%>
                        <span class="status-badge active">Success</span>
                        <%} else {%>
                        <span class="status-badge suspended">Failed</span>
                        <%}%>
                      </td>
                    </tr>
                  </tbody>
                  <%})%>
                </table>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Add User Modal -->
    <div
      class="modal fade"
      id="addUserModal"
      tabindex="-1"
      aria-labelledby="addUserModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addUserModalLabel">Add New User</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="addUserForm">
              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="userFirstName" class="form-label">First Name</label>
                    <input type="text" class="form-control" id="userFirstName" required />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="userLastName" class="form-label">Last Name</label>
                    <input type="text" class="form-control" id="userLastName" required />
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label for="userEmail" class="form-label">Email Address</label>
                <input type="email" class="form-control" id="userEmail" required />
              </div>

              <div class="mb-3">
                <label for="userRole" class="form-label">User Role</label>
                <select class="form-select" id="userRole" required>
                  <option value="">Select Role</option>
                  <option value="buyer">Buyer</option>
                  <option value="supplier">Supplier</option>
                  <option value="admin">Admin</option>
                  <option value="moderator">Moderator</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="userPassword" class="form-label">Password</label>
                <input type="password" class="form-control" id="userPassword" required />
                <div class="form-text">
                  Minimum 8 characters with uppercase, lowercase and number
                </div>
              </div>

              <div class="mb-3">
                <label for="userStatus" class="form-label">Account Status</label>
                <select class="form-select" id="userStatus">
                  <option value="active">Active</option>
                  <option value="pending">Pending</option>
                  <option value="suspended">Suspended</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" form="addUserForm" class="btn btn-primary">Add User</button>
          </div>
        </div>
      </div>
    </div>

    <!-- View User Modal -->
    <div class="modal fade" id="viewUserModal" tabindex="-1">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <!-- Header -->
          <div class="modal-header">
            <h5 class="modal-title">User Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <!-- Body -->
          <div class="modal-body">
            <!-- Tabs -->
            <ul class="nav nav-tabs" id="userDetailTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button
                  class="nav-link active"
                  id="profile-tab-btn"
                  data-bs-toggle="tab"
                  data-bs-target="#profile-tab"
                  type="button"
                  role="tab"
                  aria-controls="profile-tab"
                  aria-selected="true"
                >
                  Profile
                </button>
              </li>

              <li class="nav-item" role="presentation">
                <button
                  class="nav-link"
                  id="orders-tab-btn"
                  data-bs-toggle="tab"
                  data-bs-target="#orders-tab"
                  type="button"
                  role="tab"
                  aria-controls="orders-tab"
                  aria-selected="false"
                >
                  Orders
                </button>
              </li>

              <li class="nav-item" role="presentation">
                <button
                  class="nav-link"
                  id="activity-tab-btn"
                  data-bs-toggle="tab"
                  data-bs-target="#activity-tab"
                  type="button"
                  role="tab"
                  aria-controls="activity-tab"
                  aria-selected="false"
                >
                  Activity
                </button>
              </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content mt-3">
              <div
                class="tab-pane fade show active"
                id="profile-tab"
                role="tabpanel"
                aria-labelledby="profile-tab-btn"
              >
                <div id="profile-content"></div>
              </div>

              <div
                class="tab-pane fade"
                id="orders-tab"
                role="tabpanel"
                aria-labelledby="orders-tab-btn"
              >
                <div id="orders-content"></div>
              </div>

              <div
                class="tab-pane fade"
                id="activity-tab"
                role="tabpanel"
                aria-labelledby="activity-tab-btn"
              >
                <div id="activity-content"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 🔴 Suspend User Modal -->
    <div class="modal fade" id="suspendUserModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal">
          <!-- Header -->
          <div class="modal-header border-0">
            <h5 class="modal-title fw-bold text-danger">
              <i class="bi bi-exclamation-triangle me-2"></i>
              Suspend User
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <!-- Body -->
          <div class="modal-body">
            <p class="text-muted mb-3">Please provide a reason for suspending this user.</p>

            <input type="hidden" id="suspendUserId" />

            <div class="mb-3">
              <label class="form-label fw-semibold">Reason</label>
              <textarea
                id="suspendReason"
                class="form-control custom-textarea"
                rows="3"
                placeholder="e.g. Fraud activity, spam, misuse..."
              ></textarea>
            </div>
          </div>

          <!-- Footer -->
          <div class="modal-footer border-0">
            <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
            <button class="btn btn-danger" id="confirmSuspendBtn">Suspend User</button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="actionModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="actionModalTitle">Confirm Action</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body" id="actionModalBody">Are you sure?</div>

          <div class="modal-footer">
            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button class="btn btn-primary" id="confirmActionBtn">Confirm</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="../assets/js/main.js"></script>
    <!-- <script src="../assets/js/admin/users.js"></script> -->
    <script type="module" src="../assets/js/admin/users/user.main.js"></script>
  </body>
</html>
