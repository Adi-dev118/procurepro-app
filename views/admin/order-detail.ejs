                  <i class="bi bi-box-seam me-2" style="color: var(--primary-color)"></i>Order Items
                </h5>
                <span class="item-count-badge" id="itemCountBadge">0 items</span>
              </div>
              <div class="table-responsive">
                <table class="order-items-table">
