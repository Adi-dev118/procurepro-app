            </div>
          </div>
          <!-- end #orderContent -->
        </div>
      </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/main.js"></script>

    <script>
      // ============================================================
      // Order Detail Page — reads order ID from URL, calls API
      // API endpoint: GET /admin/orders/:id
      // Expected response shape: { orderProducts: [...] }
      // ============================================================

      function getOrderIdFromUrl() {
        const parts = window.location.pathname.split('/');
        return parts[parts.length - 1];
      }

      function formatCurrency(amount) {
        return '₹' + Number(amount).toLocaleString('en-IN');
      }

      function formatDate(dateStr) {
        const d = new Date(dateStr);
        return d.toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      }

      function getInitials(name) {
        return name
          .split(' ')
          .map((w) => w[0])
          .join('')
          .toUpperCase()
          .slice(0, 2);
      }

      function capitalize(str) {
        return str ? str.charAt(0).toUpperCase() + str.slice(1) : '—';
      }

      function statusBadge(status) {
        const s = (status || '').toLowerCase();
        return `<span class="s-badge ${s}">${capitalize(s)}</span>`;
      }

      function render(orderId, products) {
        // --- Hero ---
        const first = products[0];
        const totalAmount = parseFloat(first.total_amount);
        const itemsSubtotal = products.reduce((s, p) => s + p.subtotal, 0);
        const overallStatus = first.status;
        const orderDate = formatDate(first.created_at);

        document.getElementById('heroOrderId').textContent = `Order #${orderId}`;
        document.getElementById('heroDate').textContent = `Placed on ${orderDate}`;
        document.getElementById('heroItems').textContent = products.length;
        document.getElementById('heroTotal').textContent = formatCurrency(totalAmount);
        document.getElementById('heroStatus').textContent = capitalize(overallStatus);

        // --- Info cards ---
        document.getElementById('infoOrderId').textContent = `#${orderId}`;
        document.getElementById('infoDate').innerHTML = orderDate;
        document.getElementById('infoStatus').innerHTML = statusBadge(overallStatus);
        document.getElementById('infoPayment').innerHTML = statusBadge(first.payment_status);
        document.getElementById('infoAmount').textContent = formatCurrency(totalAmount);
        document.getElementById('infoSubtotal').textContent = formatCurrency(itemsSubtotal);
        document.getElementById('infoProductCount').textContent = products.length;

        const uniqueSuppliers = [...new Set(products.map((p) => p.business_name))];
        document.getElementById('infoSupplierCount').textContent = uniqueSuppliers.length;

        // --- Category breakdown ---
        const catMap = {};
        products.forEach((p) => {
          catMap[p.category_name] = (catMap[p.category_name] || 0) + 1;
        });
        const catEl = document.getElementById('categoryBreakdown');
        catEl.innerHTML = Object.entries(catMap)
          .map(
            ([cat, count]) => `
          <div class="info-row">
            <span class="ilabel">${cat}</span>
            <span class="ivalue">${count} item${count > 1 ? 's' : ''}</span>
          </div>
        `,
          )
          .join('');

        // --- Items table ---
        document.getElementById('itemCountBadge').textContent =
          `${products.length} item${products.length > 1 ? 's' : ''}`;
        const tbody = document.getElementById('itemsTableBody');
        tbody.innerHTML = products
          .map(
            (p) => `
          <tr>
            <td>
              <div class="product-cell">
                <span class="pname">${p.product_name}</span>
                <span class="pcat">#${p.id}</span>
              </div>
            </td>
            <td>
              <div class="supplier-cell">
                <div class="sup-avatar">${getInitials(p.business_name)}</div>
                <span class="sup-name">${p.business_name}</span>
              </div>
            </td>
            <td><span style="font-size:13px;color:#6b7280;">${p.category_name}</span></td>
            <td><span class="price-cell">${formatCurrency(p.price)}</span></td>
            <td><span class="qty-badge">${p.quantity}</span></td>
            <td><span class="subtotal-cell">${formatCurrency(p.subtotal)}</span></td>
            <td>${statusBadge(p.status)}</td>
            <td>${statusBadge(p.payment_status)}</td>
          </tr>
        `,
          )
          .join('');

        // --- Summary ---
        const summaryEl = document.getElementById('summaryBody');
        summaryEl.innerHTML = `
          ${products
            .map(
              (p) => `
            <div class="summary-line">
              <span class="slabel">${p.product_name} × ${p.quantity}</span>
              <span class="sval">${formatCurrency(p.subtotal)}</span>
            </div>
          `,
            )
            .join('')}
          <div class="summary-line total-line">
            <span class="slabel">Total Amount</span>
            <span class="sval">${formatCurrency(totalAmount)}</span>
          </div>
        `;

        // --- Document title ---
        document.title = `Admin Dashboard - Order #${orderId}`;
      }

      async function loadOrderDetail() {
        const orderId = getOrderIdFromUrl();
        try {
          const res = await fetch(`/admin/order/order-data/order-modal/${orderId}`);
          if (!res.ok) throw new Error('Failed to fetch order');
          const data = await res.json();

          const products = data.orderProducts;
          if (!products || !products.length) throw new Error('No products in order');

          document.getElementById('pageLoading').style.display = 'none';
          document.getElementById('orderContent').style.display = 'block';

          render(orderId, products);
        } catch (err) {
          document.getElementById('pageLoading').innerHTML = `
            <div class="page-error">
              <i class="bi bi-exclamation-circle" style="font-size:40px;display:block;margin-bottom:10px;animation:none;"></i>
              <p>Failed to load order details. Please try again.</p>
              <a href="/admin/orders" class="btn btn-outline-primary mt-2">← Back to Orders</a>
            </div>
          `;
          console.error(err);
        }
      }

      document.addEventListener('DOMContentLoaded', loadOrderDetail);
    </script>
  </body>
</html>
