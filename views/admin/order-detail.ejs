                  <div class="info-row">
                    <span class="ilabel">Date</span>
                    <span class="ivalue" id="infoDate">—</span>
                  </div>
                  <div class="info-row">
                    <span class="ilabel">Status</span>
                    <span class="ivalue" id="infoStatus">—</span>
                  </div>
                  <div class="info-row">
                    <span class="ilabel">Payment</span>
                    <span class="ivalue" id="infoPayment">—</span>
                  </div>
                </div>
              </div>

              <!-- Amount Breakdown -->
              <div class="col-md-4">
                <div class="info-card">
                  <div class="info-card-title"><i class="bi bi-currency-rupee"></i> Amount</div>
                  <div class="info-row">
                    <span class="ilabel">Total Amount</span>
                    <span class="ivalue" id="infoAmount">—</span>
                  </div>
                  <div class="info-row">
                    <span class="ilabel">Items Subtotal</span>
                    <span class="ivalue" id="infoSubtotal">—</span>
                  </div>
                  <div class="info-row">
                    <span class="ilabel">Products</span>
                    <span class="ivalue" id="infoProductCount">—</span>
                  </div>
                  <div class="info-row">
                    <span class="ilabel">Suppliers</span>
                    <span class="ivalue" id="infoSupplierCount">—</span>
