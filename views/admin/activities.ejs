<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Activity Logs</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/assets/css/style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />

    <style>
      /* ===== Activity Logs Page ===== */

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--primary-color);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        margin-bottom: 20px;
        transition: gap 0.2s;
      }
      .back-link:hover {
        gap: 10px;
        color: var(--secondary-color);
      }

      /* ===== Hero Banner ===== */
      .activity-hero {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        border-radius: 14px;
        padding: 24px 30px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
      }
      .activity-hero::before {
        content: '';
        position: absolute;
        top: -50px;
        right: -50px;
        width: 190px;
        height: 190px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.06);
      }
      .activity-hero::after {
        content: '';
        position: absolute;
        bottom: -55px;
        right: 110px;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
      }
      .hero-left h2 {
        font-size: 22px;
        font-weight: 800;
        margin-bottom: 4px;
      }
      .hero-left p {
        font-size: 13px;
        opacity: 0.78;
        margin: 0;
      }
      .hero-metrics {
        display: flex;
        gap: 28px;
        align-items: center;
        flex-shrink: 0;
      }
      .hero-metric {
        text-align: center;
      }
      .hero-metric .val {
        font-size: 22px;
        font-weight: 700;
        display: block;
      }
      .hero-metric .lbl {
        font-size: 11px;
        opacity: 0.72;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .hero-divider {
        width: 1px;
        height: 40px;
        background: rgba(255, 255, 255, 0.18);
      }

      /* ===== Filters Bar ===== */
      .filters-bar {
        background: white;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        padding: 16px 20px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }
      .filters-bar .search-input-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
      }
      .filters-bar .search-input-wrap i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 15px;
      }
      .filters-bar .search-input-wrap input {
        width: 100%;
        padding: 9px 14px 9px 36px;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        font-size: 14px;
        color: #374151;
        outline: none;
        transition: border-color 0.2s;
      }
      .filters-bar .search-input-wrap input:focus {
        border-color: var(--primary-color);
      }
      .filter-select {
        padding: 9px 14px;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        font-size: 14px;
        color: #374151;
        outline: none;
        background: white;
        cursor: pointer;
        transition: border-color 0.2s;
        min-width: 140px;
      }
      .filter-select:focus {
        border-color: var(--primary-color);
      }
      .btn-clear-filters {
        padding: 9px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        font-size: 13.5px;
        font-weight: 500;
        color: #6b7280;
        background: white;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
      }
      .btn-clear-filters:hover {
        border-color: #ef4444;
        color: #ef4444;
        background: #fff5f5;
      }
      .total-label {
        font-size: 13px;
        color: #9ca3af;
        font-weight: 500;
        white-space: nowrap;
      }
      .total-label strong {
        color: #374151;
      }

      /* ===== Table Container ===== */
      .activity-table-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        overflow: hidden;
      }
      .activity-table-header {
        padding: 16px 22px;
        border-bottom: 2px solid #f0f0f5;
        background: #fafbff;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .activity-table-header h5 {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .page-info-badge {
        font-size: 12px;
        color: #6b7280;
        font-weight: 500;
        background: #f3f4f6;
        padding: 4px 11px;
        border-radius: 20px;
      }

      /* ===== Activity Table ===== */
      .activity-table {
        width: 100%;
        border-collapse: collapse;
      }
      .activity-table thead {
        background: #f8f9fc;
      }
      .activity-table th {
        padding: 13px 20px;
        font-size: 11.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: #6b7280;
        text-align: left;
        border-bottom: 2px solid #eaeef4;
        white-space: nowrap;
      }
      .activity-table td {
        padding: 14px 20px;
        font-size: 14px;
        color: #374151;
        border-bottom: 1px solid #f3f4f6;
        vertical-align: middle;
      }
      .activity-table tr:last-child td {
        border-bottom: none;
      }
      .activity-table tr:hover td {
        background: #f8f9ff;
      }

      /* Timestamp */
      .ts-cell {
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .ts-date {
        font-size: 13.5px;
        font-weight: 600;
        color: #111827;
      }
      .ts-time {
        font-size: 12px;
        color: #9ca3af;
      }

      /* User cell */
      .user-cell {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .user-av {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--primary-color);
        color: white;
        font-size: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .user-name-text {
        font-size: 14px;
        font-weight: 600;
        color: #111827;
      }

      /* IP cell */
      .ip-cell {
        font-family: 'Courier New', monospace;
        font-size: 13px;
        background: #f3f4f6;
        padding: 4px 9px;
        border-radius: 6px;
        color: #374151;
        display: inline-block;
      }

      /* Activity log */
      .log-cell {
        font-size: 13.5px;
        color: #374151;
        max-width: 300px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      /* Status badge */
      .s-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
      }
      .s-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        display: inline-block;
      }
      .s-badge.success {
        background: #d1fae5;
        color: #065f46;
      }
      .s-badge.success::before {
        background: #10b981;
      }
      .s-badge.failed {
        background: #fee2e2;
        color: #991b1b;
      }
      .s-badge.failed::before {
        background: #ef4444;
      }
      .s-badge.warning {
        background: #fef3c7;
        color: #92400e;
      }
      .s-badge.warning::before {
        background: #f59e0b;
      }
      .s-badge.info {
        background: #dbeafe;
        color: #1e40af;
      }
      .s-badge.info::before {
        background: #3b82f6;
      }

      /* ===== Pagination ===== */
      .pagination-wrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 22px;
        border-top: 1px solid #f0f0f5;
        flex-wrap: wrap;
        gap: 12px;
        background: #fafbff;
      }
      .pagination-info {
        font-size: 13.5px;
        color: #6b7280;
      }
      .pagination-info strong {
        color: #111827;
      }
      .pagination {
        display: flex;
        gap: 4px;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .pagination .page-item .page-link {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 13.5px;
        font-weight: 500;
        color: #374151;
        border: 1.5px solid #e5e7eb;
        background: white;
        text-decoration: none;
        transition: all 0.18s;
      }
      .pagination .page-item .page-link:hover {
        border-color: var(--primary-color);
        color: var(--primary-color);
        background: #eef2ff;
      }
      .pagination .page-item.active .page-link {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
      }
      .pagination .page-item.disabled .page-link {
        color: #d1d5db;
        pointer-events: none;
        border-color: #f3f4f6;
        background: #f9fafb;
      }
      .pagination .page-item.ellipsis .page-link {
        border: none;
        background: transparent;
        pointer-events: none;
        color: #9ca3af;
      }

      /* ===== Empty / Loading ===== */
      .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #9ca3af;
      }
      .empty-state i {
        font-size: 48px;
        display: block;
        margin-bottom: 14px;
      }
      .empty-state p {
        font-size: 15px;
        font-weight: 500;
        margin: 0;
      }

      /* ===== Log Tooltip on hover ===== */
      .log-cell[title] {
        cursor: help;
      }
    </style>
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>
        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard"
                ><i class="bi bi-speedometer2"></i><span class="menu-text">Dashboard</span></a
              >
            </li>
            <li>
              <a href="/admin/users" class="active">
                <i class="bi bi-people"></i><span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers"
                ><i class="bi bi-truck"></i><span class="menu-text">Supplier Management</span></a
              >
            </li>
            <li>
              <a href="/admin/products"
                ><i class="bi bi-box-seam"></i><span class="menu-text">Product Management</span></a
              >
            </li>
            <li>
              <a href="/admin/orders"
                ><i class="bi bi-cart-check"></i><span class="menu-text">Order Management</span></a
              >
            </li>
            <li>
              <a href="/admin/disputes"
                ><i class="bi bi-exclamation-triangle"></i
                ><span class="menu-text">Dispute Center</span></a
              >
            </li>
            <li>
              <a href="/admin/settings"
                ><i class="bi bi-gear"></i><span class="menu-text">System Settings</span></a
              >
            </li>
          </ul>
        </nav>
        <div class="sidebar-footer"><p>AdminPanel v1.0</p></div>
      </aside>

      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn"><i class="bi bi-list"></i></button>
          <h1 class="page-title">Activity Logs</h1>
          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>
            <div class="notification-badge"><i class="bi bi-bell"></i><span>3</span></div>
            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>
              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/profile"
                    ><i class="bi bi-person me-2"></i>My Profile</a
                  >
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/settings"
                    ><i class="bi bi-gear me-2"></i>System Settings</a
                  >
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item text-danger" href="/company/login" id="signoutButton"
                    ><i class="bi bi-box-arrow-right me-2"></i>Sign Out</a
                  >
                </li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper">
          <!-- Back link -->
          <a href="/admin/users" class="back-link">
            <i class="bi bi-arrow-left"></i>
            Back to User Management
          </a>

          <!-- Hero Banner -->
          <div class="activity-hero">
            <div class="hero-left">
              <h2><i class="bi bi-activity me-2" style="opacity: 0.85"></i>User Activity Logs</h2>
              <p>Complete audit trail of all user actions across the platform</p>
            </div>
            <div class="hero-metrics">
              <div class="hero-metric">
                <span class="val" id="heroTotal">></span>
                <span class="lbl">Total Logs</span>
              </div>
              <div class="hero-divider"></div>
              <div class="hero-metric">
                <span class="val" id="heroPage"></span>
                <span class="lbl">Page</span>
              </div>
              <div class="hero-divider"></div>
              <div class="hero-metric">
                <span class="val">5</span>
                <span class="lbl">Per Page</span>
              </div>
            </div>
          </div>

          <!-- Filters Bar -->
          <div class="filters-bar">
            <div class="search-input-wrap">
              <i class="bi bi-search"></i>
              <input
                type="text"
                id="filterSearch"
                placeholder="Search by user or activity..."
              />
            </div>

            <select class="filter-select" id="filterStatus">
              <option value="">All Statuses</option>
              <option value="success">Success</option>
              <option value="failed">Failed</option>
              <option value="warning">Warning</option>
              <option value="info">Info</option>
            </select>

            <button class="btn-clear-filters">
              <i class="bi bi-x-circle me-1"></i>Clear Filters
            </button>

            <span class="total-label"
              >Showing <strong id="showingCount">—</strong> of <strong></strong> records</span
            >
          </div>

          <!-- Table Card -->
          <div class="activity-table-card">
            <div class="activity-table-header">
              <h5>
                <i class="bi bi-journal-text" style="color: var(--primary-color)"></i>
                Activity Records
              </h5>
              <span class="page-info-badge" id="pageInfoBadge">Page ></span>
            </div>

            <div class="table-responsive">
              <table class="activity-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>IP Address</th>
                    <th>Activity</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="activityTableBody"></tbody>
              </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container">
              <div class="pagination-info-activity"></div>
              <nav>
                <ul class="pagination" id="activity-pagination"></ul>
              </nav>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/main.js"></script>
    <script type="module" src="../assets/js/admin/activities/activity.main.js"></script>
  </body>
</html>
