<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Product Management</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="../assets/css/style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/admin/users">
                <i class="bi bi-people"></i>
                <span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers">
                <i class="bi bi-truck"></i>
                <span class="menu-text">Supplier Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/products" class="active">
                <i class="bi bi-box-seam"></i>
                <span class="menu-text">Product Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/orders">
                <i class="bi bi-cart-check"></i>
                <span class="menu-text">Order Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/disputes">
                <i class="bi bi-exclamation-triangle"></i>
                <span class="menu-text">Dispute Center</span>
              </a>
            </li>
            <li>
              <a href="/admin/settings">
                <i class="bi bi-gear"></i>
                <span class="menu-text">System Settings</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="sidebar-footer">
          <p>AdminPanel v1.0</p>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="page-title">Product Management</h1>

          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/profile">
                    <i class="bi bi-person me-2"></i>My Profile</a
                  >
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/settings">
                    <i class="bi bi-gear me-2"></i>System Settings</a
                  >
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item text-danger" href="/company/login" id="signoutButton">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out</a
                  >
                </li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper products-page">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title">Product Management</h1>
            <div>
              <button
                class="btn btn-primary me-2"
                data-bs-toggle="modal"
                data-bs-target="#addProductModal"
              >
                <i class="bi bi-plus-circle me-2"></i>
                Add Product
              </button>
              <button
                class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#bulkEditModal"
              >
                <i class="bi bi-pencil-square me-2"></i>
                Bulk Edit
              </button>
            </div>
          </div>

          <!-- Product Stats -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Total Products</h6>
                      <h3 class="mb-0"><%=products%></h3>
                    </div>
                    <div class="stat-icon bg-primary">
                      <i class="bi bi-box"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 8.5% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Active Listings</h6>
                      <h3 class="mb-0"><%=approved%></h3>
                    </div>
                    <div class="stat-icon bg-success">
                      <i class="bi bi-check-circle"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 6.2% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Inactive Listings</h6>
                      <h3 class="mb-0"><%=inactive%></h3>
                    </div>
                    <div class="stat-icon bg-warning">
                      <i class="bi bi-pause-circle"></i>
                    </div>
                  </div>
                  <p class="text-danger mt-2 mb-0">
                    <i class="bi bi-arrow-down"></i> 3.1% from last month
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Avg. Price</h6>
                      <h3 class="mb-0">$ <%=avgPrice%></h3>
                    </div>
                    <div class="stat-icon bg-info">
                      <i class="bi bi-tag"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 2.4% from last month
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Products Table -->
          <div class="table-container">
            <div class="table-header">
              <div class="table-actions">
                <div>
                  <div class="input-group" style="width: 300px">
                    <input
                      type="text"
                      name="search"
                      class="form-control"
                      placeholder="Search products..." data-type="products"
                    />
                    <button class="btn btn-outline-secondary search-btn" type="button">
                      <i class="bi bi-search"></i>
                    </button>
                  </div>
                </div>
                <div class="btn-group">
                  <button
                    class="btn btn-outline-secondary dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                  >
                    <i class="bi bi-filter me-1"></i> Status
                  </button>
                  <ul class="dropdown-menu">
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="active"
                        >Active</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="suspended"
                        >Suspended</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="pending"
                        >Pending</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item status-filter" href="#" data-status="rejected"
                        >Rejected</a
                      >
                    </li>
                  </ul>
                </div>
                <div class="btn-group">
                  <button
                    id="category-btn"
                    class="btn btn-outline-secondary dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                  >
                    <i class="bi bi-filter me-1"></i> Category
                  </button>

                  <ul class="dropdown-menu" id="category-filter"></ul>
                </div>
                <div class="btn-group">
                  <button
                    class="btn btn-outline-secondary dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                  >
                    <i class="bi bi-filter me-1"></i> Stock
                  </button>
                  <ul class="dropdown-menu">
                    <li>
                      <a class="dropdown-item stock-filter" href="#" data-stock="in"
                        >In Stock</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item stock-filter" href="#" data-stock="low"
                        >Low Stock</a
                      >
                    </li>
                    <li>
                      <a class="dropdown-item stock-filter" href="#" data-stock="out"
                        >Out of Stock</a
                      >
                    </li>
                  </ul>
                </div>
                <button class="btn btn-outline-secondary">
                  <i class="bi bi-download me-2"></i>
                  Export
                </button>
                <button class="btn btn-outline-danger clear-filters">Clear Filters</button>
              </div>
            </div>

            <div class="table-responsive">
              <table class="table table-hover" data-sortable="true">
                <thead>
                  <tr>
                    <th>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="selectAll" />
                      </div>
                    </th>
                    <th>Product</th>
                    <th>SKU</th>
                    <th>Category</th>
                    <th>Supplier</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="product-body"></tbody>
              </table>
            </div>
            <div class="pagination-container">
              <div class="pagination-info"></div>
              <nav>
                <ul class="pagination" id="pagination"></ul>
              </nav>
            </div>
          </div>

          <!-- Category Management -->
          <div class="row mt-5">
            <div class="col-lg-8">
              <div class="form-section">
                <h3 class="section-title mb-4">Category Management</h3>
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label for="categoryName" class="form-label">Category Name</label>
                      <input
                        type="text"
                        class="form-control"
                        id="categoryName"
                        placeholder="Enter new category"
                      />
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label for="parentCategory" class="form-label">Parent Category</label>
                      <select class="form-select" id="parentCategory">
                        <option value="">None (Top Level)</option>
                        <option value="electronics">Electronics</option>
                        <option value="fashion">Fashion</option>
                        <option value="home">Home & Garden</option>
                      </select>
                    </div>
                  </div>
                </div>
                <div class="mb-3">
                  <label for="categoryDescription" class="form-label">Description</label>
                  <textarea class="form-control" id="categoryDescription" rows="2"></textarea>
                </div>
                <button class="btn btn-primary">Add Category</button>
              </div>

              <!-- Existing Categories -->
              <div class="table-container mt-4">
                <div class="table-header">
                  <h5>Existing Categories</h5>
                </div>
                <div class="table-responsive">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Category</th>
                        <th>Products</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <%categories.forEach(category=> {%>
                      <tr>
                        <td>
                          <strong><%=category.name%></strong>
                          <div class="text-muted small"><%=category.description%></div>
                        </td>
                        <td><%=category.totalProducts%></td>
                        <td>
                          <%if(category.status === 'active'){%>
                          <span class="status-badge active">Active</span>
                          <%}else{%>
                          <span class="status-badge suspended">Inactive</span>
                          <%}%>
                        </td>
                        <td>
                          <div class="action-buttons">
                            <button class="btn-icon edit" title="Edit">
                              <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn-icon delete" title="Delete">
                              <i class="bi bi-trash"></i>
                            </button>
                          </div>
                        </td>
                      </tr>

                      <%})%>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <div class="col-lg-4">
              <div class="form-section">
                <h3 class="section-title mb-4">Featured Products</h3>
                <div class="mb-3">
                  <label class="form-label">Select Featured Products</label>
                  <select class="form-select" multiple size="6">
                    <option>Wireless Bluetooth Headphones</option>
                    <option>Smart Watch Pro</option>
                    <option>Designer Handbag</option>
                    <option>The Great Novel</option>
                    <option>Modern Table Lamp</option>
                    <option>Premium Coffee Maker</option>
                  </select>
                  <div class="form-text">Hold Ctrl to select multiple products</div>
                </div>
                <button class="btn btn-primary">Update Featured</button>
              </div>

              <!-- Product Complaints -->
              <div class="form-section mt-4">
                <h3 class="section-title mb-4">Recent Product Complaints</h3>
                <div class="complaint-list">
                  <div class="complaint-item mb-3 p-3 border rounded">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <strong>Misleading Description</strong>
                        <div class="text-muted small">Premium Headphones - TechGadgets Ltd</div>
                      </div>
                      <span class="badge bg-warning">Pending</span>
                    </div>
                    <p class="mb-1 mt-2 small">
                      Customer reports product description doesn't match actual features
                    </p>
                    <div class="text-end">
                      <button class="btn btn-sm btn-outline-primary mt-2">Review</button>
                    </div>
                  </div>
                  <div class="complaint-item mb-3 p-3 border rounded">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <strong>Counterfeit Item</strong>
                        <div class="text-muted small">Designer Handbag - Sarah Johnson</div>
                      </div>
                      <span class="badge bg-danger">Resolved</span>
                    </div>
                    <p class="mb-1 mt-2 small">Item removed, supplier notified</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Add Product Modal -->
    <div
      class="modal fade"
      id="addProductModal"
      tabindex="-1"
      aria-labelledby="addProductModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addProductModalLabel">Add New Product</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="addProductForm">
              <div class="mb-3">
                <label for="productName" class="form-label">Product Name</label>
                <input type="text" class="form-control" id="productName" required />
              </div>

              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="productSKU" class="form-label">SKU</label>
                    <input type="text" class="form-control" id="productSKU" required />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="productCategory" class="form-label">Category</label>
                    <select class="form-select" id="productCategory" required>
                      <option value="">Select Category</option>
                      <option value="electronics">Electronics</option>
                      <option value="fashion">Fashion</option>
                      <option value="home">Home & Garden</option>
                      <option value="books">Books</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="productPrice" class="form-label">Price ($)</label>
                    <input
                      type="number"
                      class="form-control"
                      id="productPrice"
                      step="0.01"
                      required
                    />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="productStock" class="form-label">Stock Quantity</label>
                    <input type="number" class="form-control" id="productStock" required />
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label for="productSupplier" class="form-label">Supplier</label>
                <select class="form-select" id="productSupplier" required>
                  <option value="">Select Supplier</option>
                  <option value="sarah">Sarah Johnson</option>
                  <option value="tech">TechGadgets Ltd</option>
                  <option value="global">Global Supplies Inc.</option>
                  <option value="home">Home Furnishings</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="productDescription" class="form-label">Description</label>
                <textarea class="form-control" id="productDescription" rows="3" required></textarea>
              </div>

              <div class="mb-3">
                <label for="productTags" class="form-label">Tags</label>
                <input
                  type="text"
                  class="form-control"
                  id="productTags"
                  placeholder="Separate tags with commas"
                />
                <div class="form-text">e.g., wireless, bluetooth, headphones, audio</div>
              </div>

              <div class="mb-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="productFeatured" />
                  <label class="form-check-label" for="productFeatured">
                    Feature this product
                  </label>
                </div>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" form="addProductForm" class="btn btn-primary">Add Product</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bulk Edit Modal -->
    <div
      class="modal fade"
      id="bulkEditModal"
      tabindex="-1"
      aria-labelledby="bulkEditModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="bulkEditModalLabel">Bulk Edit Products</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label"
                >Selected Products: <span class="text-muted">5 products</span></label
              >
            </div>

            <div class="mb-3">
              <label for="bulkStatus" class="form-label">Update Status</label>
              <select class="form-select" id="bulkStatus">
                <option value="">-- No Change --</option>
                <option value="active">Activate</option>
                <option value="inactive">Deactivate</option>
              </select>
            </div>

            <div class="mb-3">
              <label for="bulkCategory" class="form-label">Update Category</label>
              <select class="form-select" id="bulkCategory">
                <option value="">-- No Change --</option>
                <option value="electronics">Electronics</option>
                <option value="fashion">Fashion</option>
                <option value="home">Home & Garden</option>
              </select>
            </div>

            <div class="mb-3">
              <label for="bulkPriceAdjustment" class="form-label">Price Adjustment</label>
              <div class="input-group">
                <select class="form-select" style="max-width: 120px">
                  <option value="increase">Increase by</option>
                  <option value="decrease">Decrease by</option>
                  <option value="set">Set to</option>
                </select>
                <input type="number" class="form-control" placeholder="Amount" step="0.01" />
                <span class="input-group-text">$</span>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary">Apply Changes</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="../assets/js/main.js"></script>
    <script type="module" src="../assets/js/admin/product/product.main.js"></script>
  </body>
</html>
