<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Overview</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/assets/css/style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />
  </head>
  <body>
    <div class="dashboard-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="logo">
            <i class="bi bi-shop logo-icon"></i>
            <span class="logo-text">AdminPanel</span>
          </div>
          <button class="toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="sidebar-menu">
          <ul>
            <li>
              <a href="/admin/dashboard" class="active">
                <i class="bi bi-speedometer2"></i>
                <span class="menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/admin/users">
                <i class="bi bi-people"></i>
                <span class="menu-text">User Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/suppliers">
                <i class="bi bi-truck"></i>
                <span class="menu-text">Supplier Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/products">
                <i class="bi bi-box-seam"></i>
                <span class="menu-text">Product Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/orders">
                <i class="bi bi-cart-check"></i>
                <span class="menu-text">Order Management</span>
              </a>
            </li>
            <li>
              <a href="/admin/disputes">
                <i class="bi bi-exclamation-triangle"></i>
                <span class="menu-text">Dispute Center</span>
              </a>
            </li>
            <li>
              <a href="/admin/settings">
                <i class="bi bi-gear"></i>
                <span class="menu-text">System Settings</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="sidebar-footer">
          <p>AdminPanel v1.0</p>
        </div>
      </aside>

      <!-- Mobile overlay (for mobile menu) -->
      <div class="mobile-overlay"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
          <button class="mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="page-title">Dashboard Overview</h1>

          <div class="topbar-actions">
            <div class="search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="user-profile dropdown" style="position: relative">
              <button
                id="adminDropdownBtn"
                class="d-flex align-items-center gap-2 btn border-0"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <div class="user-avatar"><span>AD</span></div>
                <span class="user-name">Admin User</span>
                <i class="bi bi-chevron-down"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px">
                <li class="px-3 py-2 border-bottom">
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar"><span>AD</span></div>
                    <div>
                      <div class="fw-medium">Admin User</div>
                      <small class="text-muted">admin@panel.com</small>
                    </div>
                  </div>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/profile">
                    <i class="bi bi-person me-2"></i>My Profile</a
                  >
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/settings">
                    <i class="bi bi-gear me-2"></i>System Settings</a
                  >
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item text-danger" href="/company/login" id="signoutButton">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out</a
                  >
                </li>
              </ul>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="content-wrapper dashboard-page">
          <!-- KPI Cards -->
          <div class="kpi-cards">
            <div class="kpi-card revenue">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Total Revenue</h3>
                <i class="bi bi-currency-dollar"></i>
              </div>
              <div class="kpi-card-value">$<%=ordersStats.totalRevenue %></div>
              <div class="kpi-card-change positive">↑ 12% from last month</div>
            </div>

            <div class="kpi-card orders">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Total Orders</h3>
                <i class="bi bi-cart"></i>
              </div>
              <div class="kpi-card-value"><%=ordersStats.totalOrders %></div>
              <div class="kpi-card-change positive">↑ 8% from last week</div>
            </div>

            <div class="kpi-card users">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Total Users</h3>
                <i class="bi bi-people-fill"></i>
              </div>
              <div class="kpi-card-value"><%=platformStats.totalUsers%></div>
              <div class="kpi-card-change positive">↑ 5% from last month</div>
            </div>

            <div class="kpi-card suppliers">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Active Suppliers</h3>
                <i class="bi bi-building"></i>
              </div>
              <div class="kpi-card-value"><%=platformStats.totalSuppliers%></div>
              <div class="kpi-card-change negative">↓ 2% from last month</div>
            </div>

            <div class="kpi-card commission">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Commission Earned</h3>
                <i class="bi bi-graph-up"></i>
              </div>
              <div class="kpi-card-value">$ <%=ordersStats.totalCommission%></div>
              <div class="kpi-card-change positive">↑ 15% from last month</div>
            </div>

            <div class="kpi-card disputes">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Pending Disputes</h3>
                <i class="bi bi-exclamation-octagon"></i>
              </div>
              <div class="kpi-card-value"><%=platformStats.totalDisputes%></div>
              <div class="kpi-card-change positive">↓ 3 from yesterday</div>
            </div>

            <div class="kpi-card shipments">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Pending Shipments</h3>
                <i class="bi bi-truck"></i>
              </div>
              <div class="kpi-card-value"><%=ordersStats.pendingShipments%></div>
              <div class="kpi-card-change negative">↑ 12 from yesterday</div>
            </div>

            <div class="kpi-card uptime">
              <div class="kpi-card-header">
                <h3 class="kpi-card-title">Platform Uptime</h3>
                <i class="bi bi-hdd-stack"></i>
              </div>
              <div class="kpi-card-value">99.9%</div>
              <div class="kpi-card-change positive">Last 30 days</div>
            </div>
          </div>

          <!-- Charts Section -->
          <div class="charts-section">
            <h2 class="section-title">Revenue & Growth Analytics</h2>

            <div class="row">
              <div class="col-lg-8">
                <div class="chart-container">
                  <div class="chart-header">
                    <h3 class="chart-title">Monthly Revenue Trend</h3>
                    <div class="dropdown">
                      <button
                        class="btn btn-outline-secondary btn-sm dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                      >
                        Last 6 months
                      </button>
                      <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Last 3 months</a></li>
                        <li><a class="dropdown-item" href="#">Last 6 months</a></li>
                        <li><a class="dropdown-item" href="#">Last 12 months</a></li>
                      </ul>
                    </div>
                  </div>
                  <div class="chart-placeholder">
                    <i class="bi bi-bar-chart me-2"></i>
                    Monthly Revenue Chart (Placeholder)
                  </div>
                </div>
              </div>

              <div class="col-lg-4">
                <div class="chart-container">
                  <div class="chart-header">
                    <h3 class="chart-title">User Growth</h3>
                  </div>
                  <div class="chart-placeholder">
                    <i class="bi bi-pie-chart me-2"></i>
                    User Growth Chart (Placeholder)
                  </div>
                </div>
              </div>
            </div>

            <div class="row mt-4">
              <div class="col-lg-6">
                <div class="chart-container">
                  <div class="chart-header">
                    <h3 class="chart-title">Order Status Distribution</h3>
                  </div>
                  <div class="chart-placeholder">
                    <i class="bi bi-pie-chart-fill me-2"></i>
                    Order Status Chart (Placeholder)
                  </div>
                </div>
              </div>

              <div class="col-lg-6">
                <div class="chart-container">
                  <div class="chart-header">
                    <h3 class="chart-title">Top Selling Categories</h3>
                  </div>
                  <div class="chart-placeholder">
                    <i class="bi bi-graph-up-arrow me-2"></i>
                    Top Categories Chart (Placeholder)
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Activity Section -->
          <div class="mt-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h2 class="section-title">Recent Activity</h2>
              <a href="#" class="btn btn-outline-primary btn-sm">View All</a>
            </div>

            <div class="table-container">
              <div class="table-responsive">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Time</th>
                      <th>User</th>
                      <th>Activity</th>
                      <th>Details</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% activities.forEach(activity => { %>
                    <tr>
                      <td><%= activity.time %></td>
                      <td><%= activity.user_name %></td>
                      <td><%= activity.activity %></td>
                      <td><%= activity.detail %></td>

                      <td>
                        <% if(activity.status === 'Success'){ %>
                        <span class="status-badge active"><%= activity.status %></span>

                        <% } else{ %>
                        <span class="status-badge suspended"><%= activity.status %></span>

                        <% }%>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/assets/js/main.js"></script>
  </body>
</html>
