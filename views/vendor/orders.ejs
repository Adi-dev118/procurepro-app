<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vendor Dashboard - Orders</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Vendor CSS -->
    <link rel="stylesheet" href="../assets/css/vendor.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body>
    <div class="vendor-container">
      <!-- Sidebar -->
      <aside class="vendor-sidebar">
        <div class="vendor-sidebar-header">
          <div class="vendor-logo">
            <i class="bi bi-shop vendor-logo-icon"></i>
            <span class="vendor-logo-text">VendorHub</span>
          </div>
          <button class="vendor-toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="vendor-sidebar-menu">
          <ul>
            <li>
              <a href="/vendor/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="vendor-menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/vendor/products">
                <i class="bi bi-box-seam"></i>
                <span class="vendor-menu-text">Products</span>
              </a>
            </li>
            <li>
              <a href="/vendor/orders" class="active">
                <i class="bi bi-cart-check"></i>
                <span class="vendor-menu-text">Orders</span>
              </a>
            </li>
            <li>
              <a href="/vendor/rfqs">
                <i class="bi bi-chat-left-text"></i>
                <span class="vendor-menu-text">RFQs</span>
              </a>
            </li>
            <li>
              <a href="/vendor/finance">
                <i class="bi bi-credit-card"></i>
                <span class="vendor-menu-text">Finance</span>
              </a>
            </li>
            <li>
              <a href="/vendor/profile">
                <i class="bi bi-person-circle"></i>
                <span class="vendor-menu-text">Profile</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="vendor-sidebar-footer">
          <p>TechGadgets Ltd</p>
          <small>Vendor Account</small>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="vendor-mobile-overlay"></div>

      <!-- Main Content -->
      <main class="vendor-main-content">
        <!-- Topbar -->
        <header class="vendor-topbar">
          <button class="vendor-mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="vendor-page-title">Order Management</h1>

          <div class="vendor-topbar-actions">
            <div class="vendor-search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search orders..." />
            </div>

            <div class="vendor-notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="vendor-user-profile" id="profileTrigger">
              <div class="vendor-user-avatar">
                <span><%= name.split(' ').map(word => word[0]).join('').toUpperCase() %></span>
              </div>
              <span class="vendor-user-name"><%=name%></span>
              <i class="bi bi-chevron-down" id="profileChevron"></i>
            </div>

            <!-- Profile Dropdown -->
            <div class="vendor-profile-dropdown" id="profileDropdown">
              <div class="vendor-profile-dropdown-header">
                <div class="vendor-profile-dropdown-avatar">
                  <span><%=name.split(' ').map(word => word[0]).join('').toUpperCase() %></span>
                </div>
                <div class="vendor-profile-dropdown-info">
                  <strong><%=name%></strong>
                  <small><%=email%></small>
                </div>
              </div>
              <div class="vendor-profile-dropdown-divider"></div>
              <a href="/company/login" class="vendor-profile-dropdown-signout" id="signoutButton">
                <i class="bi bi-box-arrow-right"></i>
                Sign Out
              </a>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="vendor-content-wrapper vendor-orders-page">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="vendor-section-title">Order Management</h1>
            <button class="btn btn-primary">
              <i class="bi bi-download me-2"></i>
              Export Orders
            </button>
          </div>

          <!-- Order Stats -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">New Orders</h6>
                      <h3 class="mb-0"><%=newOrders%></h3>
                    </div>
                    <div class="stat-icon bg-primary">
                      <i class="bi bi-cart-plus"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 2 from yesterday
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Processing</h6>
                      <h3 class="mb-0"><%=processing%></h3>
                    </div>
                    <div class="stat-icon bg-warning">
                      <i class="bi bi-gear"></i>
                    </div>
                  </div>
                  <p class="text-danger mt-2 mb-0">
                    <i class="bi bi-arrow-down"></i> 3 from yesterday
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Shipped</h6>
                      <h3 class="mb-0"><%=shipped%></h3>
                    </div>
                    <div class="stat-icon bg-info">
                      <i class="bi bi-truck"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 5 from yesterday
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Completed</h6>
                      <h3 class="mb-0"><%=completed%></h3>
                    </div>
                    <div class="stat-icon bg-success">
                      <i class="bi bi-check-circle"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 24 from yesterday
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Tabs -->
          <ul class="nav nav-tabs vendor-nav-tabs">
            <li class="nav-item">
              <button
                type="button"
                class="nav-link active"
                id="all-orders-tab"
                data-bs-toggle="tab"
                data-bs-target="#all"
              >
                All Orders
              </button>
            </li>
            <li class="nav-item">
              <button
                type="button"
                class="nav-link"
                id="new-tab"
                data-bs-toggle="tab"
                data-bs-target="#new"
              >
                New
              </button>
            </li>
            <li class="nav-item">
              <button
                type="button"
                class="nav-link"
                id="processing-tab"
                data-bs-toggle="tab"
                data-bs-target="#processing"
              >
                Processing
              </button>
            </li>
            <li class="nav-item">
              <button
                type="button"
                class="nav-link"
                id="completed-tab"
                data-bs-toggle="tab"
                data-bs-target="#completed"
              >
                Completed
              </button>
            </li>
          </ul>

          <!-- Tab Content -->
          <!-- Tabs -->
          <ul class="nav nav-tabs vendor-nav-tabs">
            ...
          </ul>

          <!-- TABLE ALWAYS VISIBLE -->
          <div class="vendor-table-container mt-3">
            <div class="vendor-table-header">
              <div class="vendor-table-actions">
                <div class="input-group" style="width: 300px">
                  <input type="text" class="form-control" placeholder="Search orders..." />
                  <button class="btn btn-outline-secondary" type="button">
                    <i class="bi bi-search"></i>
                  </button>
                </div>
              </div>
            </div>

            <div class="vendor-table-responsive">
              <table class="vendor-table">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="orders-body"></tbody>
              </table>
            </div>

            <div class="pagination-container">
              <div class="pagination-info"></div>
              <ul class="pagination" id="pagination"></ul>
            </div>
          </div>

          <!-- Order Processing Section -->
          <div class="row mt-5">
            <div class="col-lg-8">
              <div class="vendor-form-section">
                <h3 class="vendor-section-title mb-4">Bulk Order Processing</h3>
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label">Update Order Status</label>
                      <div class="input-group">
                        <select class="form-select">
                          <option>Mark as Processing</option>
                          <option>Mark as Shipped</option>
                          <option>Mark as Completed</option>
                          <option>Mark as Cancelled</option>
                        </select>
                        <button class="btn btn-primary">Apply to Selected</button>
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label">Add Tracking Numbers</label>
                      <div class="input-group">
                        <input type="text" class="form-control" placeholder="Tracking #" />
                        <button class="btn btn-primary">Add to Selected</button>
                      </div>
                      <div class="form-text">Separate multiple tracking numbers with commas</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-lg-4">
              <div class="vendor-chart-container">
                <div class="vendor-chart-header">
                  <h3 class="vendor-chart-title">Shipping Carriers</h3>
                </div>
                <div class="vendor-finance-list">
                  <div class="vendor-finance-item">
                    <div>
                      <strong>UPS</strong>
                      <div class="text-muted small">45 shipments</div>
                    </div>
                    <span class="badge bg-primary">Active</span>
                  </div>
                  <div class="vendor-finance-item">
                    <div>
                      <strong>FedEx</strong>
                      <div class="text-muted small">32 shipments</div>
                    </div>
                    <span class="badge bg-primary">Active</span>
                  </div>
                  <div class="vendor-finance-item">
                    <div>
                      <strong>USPS</strong>
                      <div class="text-muted small">18 shipments</div>
                    </div>
                    <span class="badge bg-secondary">Inactive</span>
                  </div>
                </div>
                <div class="text-center mt-3">
                  <button class="btn btn-outline-primary btn-sm">Manage Carriers</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Vendor JS -->
    <script src="../assets/js/vendor.js"></script>
    <script type="module" src="../assets/js/vendor/order/order.main.js"></script>
  </body>
</html>
