<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vendor Dashboard - RFQs</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Vendor CSS -->
    <link rel="stylesheet" href="../assets/css/vendor.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body>
    <div class="vendor-container">
      <!-- Sidebar -->
      <aside class="vendor-sidebar">
        <div class="vendor-sidebar-header">
          <div class="vendor-logo">
            <i class="bi bi-shop vendor-logo-icon"></i>
            <span class="vendor-logo-text">VendorHub</span>
          </div>
          <button class="vendor-toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="vendor-sidebar-menu">
          <ul>
            <li>
              <a href="/vendor/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="vendor-menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/vendor/products">
                <i class="bi bi-box-seam"></i>
                <span class="vendor-menu-text">Products</span>
              </a>
            </li>
            <li>
              <a href="/vendor/orders">
                <i class="bi bi-cart-check"></i>
                <span class="vendor-menu-text">Orders</span>
              </a>
            </li>
            <li>
              <a href="/vendor/rfqs" class="active">
                <i class="bi bi-chat-left-text"></i>
                <span class="vendor-menu-text">RFQs</span>
              </a>
            </li>
            <li>
              <a href="/vendor/finance">
                <i class="bi bi-credit-card"></i>
                <span class="vendor-menu-text">Finance</span>
              </a>
            </li>
            <li>
              <a href="/vendor/profile">
                <i class="bi bi-person-circle"></i>
                <span class="vendor-menu-text">Profile</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="vendor-sidebar-footer">
          <p><%= name%></p>
          <small>Vendor Account</small>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="vendor-mobile-overlay"></div>

      <!-- Main Content -->
      <main class="vendor-main-content">
        <!-- Topbar -->
        <header class="vendor-topbar">
          <button class="vendor-mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="vendor-page-title">RFQ Management</h1>

          <div class="vendor-topbar-actions">
            <div class="vendor-search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search RFQs..." />
            </div>

            <div class="vendor-notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="vendor-user-profile" id="profileTrigger">
              <div class="vendor-user-avatar">
                <span><%= name.split(' ').map(word => word[0]).join('').toUpperCase() %></span>
              </div>
              <span class="vendor-user-name"><%=name%></span>
              <i class="bi bi-chevron-down" id="profileChevron"></i>
            </div>

            <!-- Profile Dropdown -->
            <div class="vendor-profile-dropdown" id="profileDropdown">
              <div class="vendor-profile-dropdown-header">
                <div class="vendor-profile-dropdown-avatar">
                  <span><%= name.split(' ').map(word => word[0]).join('').toUpperCase() %></span>
                </div>
                <div class="vendor-profile-dropdown-info">
                  <strong><%=name%></strong>
                  <small><%=email%></small>
                </div>
              </div>
              <div class="vendor-profile-dropdown-divider"></div>
              <a href="/company/login" class="vendor-profile-dropdown-signout" id="signoutButton">
                <i class="bi bi-box-arrow-right"></i>
                Sign Out
              </a>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="vendor-content-wrapper vendor-rfqs-page">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="vendor-section-title">Request for Quotations (RFQs)</h1>
            <div>
              <button class="btn btn-outline-primary me-2">
                <i class="bi bi-download me-2"></i>
                Export RFQs
              </button>
              <button class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>
                Create RFQ Alert
              </button>
            </div>
          </div>

          <!-- RFQ Stats -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Active RFQs</h6>
                      <h3 class="mb-0"><%=activeRFQs%></h3>
                    </div>
                    <div class="stat-icon bg-primary">
                      <i class="bi bi-chat-left-text"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 3 from last week
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Quotes Submitted</h6>
                      <h3 class="mb-0"><%=quotesSubmitted%></h3>
                    </div>
                    <div class="stat-icon bg-success">
                      <i class="bi bi-check-circle"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 2 from yesterday
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Quotes Won</h6>
                      <h3 class="mb-0"><%=quotesWon%></h3>
                    </div>
                    <div class="stat-icon bg-info">
                      <i class="bi bi-trophy"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 1 from last week
                  </p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card stat-card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted">Success Rate</h6>
                      <h3 class="mb-0"><%=successRate%>%</h3>
                    </div>
                    <div class="stat-icon bg-warning">
                      <i class="bi bi-graph-up"></i>
                    </div>
                  </div>
                  <p class="text-success mt-2 mb-0">
                    <i class="bi bi-arrow-up"></i> 5% from last month
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Tabs -->
          <ul class="nav nav-tabs vendor-nav-tabs" id="rfqTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button
                class="nav-link active"
                id="active-rfqs-tab"
                data-bs-toggle="tab"
                data-bs-target="#active-rfqs"
                type="button"
              >
                Active RFQs
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="submitted-quotes-tab"
                data-bs-toggle="tab"
                data-bs-target="#submitted-quotes"
                type="button"
              >
                Submitted Quotes
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="won-quotes-tab"
                data-bs-toggle="tab"
                data-bs-target="#won-quotes"
                type="button"
              >
                Won Quotes
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="lost-quotes-tab"
                data-bs-toggle="tab"
                data-bs-target="#lost-quotes"
                type="button"
              >
                Lost Quotes
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="expired-tab"
                data-bs-toggle="tab"
                data-bs-target="#expired-rfqs"
                type="button"
              >
                Expired
              </button>
            </li>
          </ul>

          <!-- Tab Content -->
          <div class="tab-content" id="rfqTabsContent">
            <!-- Active RFQs Tab -->
            <div class="tab-pane fade show active" id="active-rfqs" role="tabpanel">
              <div id="active-rfq-cards-container" class="mt-3"></div>
            </div>

            <!-- Submitted Quotes Tab -->
            <div class="tab-pane fade" id="submitted-quotes" role="tabpanel">
              <div class="vendor-table-container mt-3">
                <div class="vendor-table-responsive">
                  <table class="vendor-table">
                    <thead>
                      <tr>
                        <th>Quote ID</th>
                        <th>RFQ Title</th>
                        <th>Submitted Date</th>
                        <th>Quote Amount</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="submitted-table-body"></tbody>
                  </table>
                </div>
              </div>
            </div>
            <div class="tab-pane fade" id="won-quotes" role="tabpanel">
              <div class="vendor-table-container mt-3">
                <div class="vendor-table-responsive">
                  <table class="vendor-table">
                    <thead>
                      <tr>
                        <th>Quote ID</th>
                        <th>RFQ Title</th>
                        <th>Submitted Date</th>
                        <th>Quote Amount</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="won-table-body"></tbody>
                  </table>
                </div>
              </div>
            </div>
            <div class="tab-pane fade" id="lost-quotes" role="tabpanel">
              <div class="vendor-table-container mt-3">
                <div class="vendor-table-responsive">
                  <table class="vendor-table">
                    <thead>
                      <tr>
                        <th>Quote ID</th>
                        <th>RFQ Title</th>
                        <th>Submitted Date</th>
                        <th>Quote Amount</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="lost-table-body"></tbody>
                  </table>
                </div>
              </div>
            </div>
            <div class="tab-pane fade show active" id="expired-rfqs" role="tabpanel">
              <div id="expired-rfq-cards-container" class="mt-3"></div>
            </div>
          </div>

          <!-- Quote Submission Form -->
          <div class="row mt-5">
            <div class="col-lg-8">
              <div class="vendor-form-section">
                <h3 class="vendor-section-title mb-4">Quick Quote Calculator</h3>
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label">Product Cost per Unit</label>
                      <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" class="form-control" placeholder="0.00" step="0.01" />
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label">Quantity</label>
                      <input type="number" class="form-control" placeholder="0" />
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label">Shipping Cost</label>
                      <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" class="form-control" placeholder="0.00" step="0.01" />
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label">Profit Margin (%)</label>
                      <div class="input-group">
                        <input type="number" class="form-control" value="20" min="0" max="100" />
                        <span class="input-group-text">%</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label">Additional Notes</label>
                  <textarea
                    class="form-control"
                    rows="3"
                    placeholder="Add any notes about the quote..."
                  ></textarea>
                </div>
                <div class="card mb-3">
                  <div class="card-body">
                    <h5 class="card-title">Quote Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Total Cost:</span>
                      <span>$0.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Shipping:</span>
                      <span>$0.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Profit (20%):</span>
                      <span>$0.00</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                      <strong>Quote Total:</strong>
                      <strong>$0.00</strong>
                    </div>
                  </div>
                </div>
                <button class="btn btn-primary">Generate Quote</button>
              </div>
            </div>

            <div class="col-lg-4">
              <div class="vendor-chart-container">
                <div class="vendor-chart-header">
                  <h3 class="vendor-chart-title">Quote Success Rate</h3>
                </div>
                <div class="vendor-chart-placeholder">
                  <i class="bi bi-pie-chart me-2"></i>
                  Success Rate Chart (Placeholder)
                </div>
              </div>

              <div class="vendor-chart-container mt-4">
                <div class="vendor-chart-header">
                  <h3 class="vendor-chart-title">Recent Quote Activity</h3>
                </div>
                <div class="vendor-finance-list">
                  <div class="vendor-finance-item">
                    <div>
                      <strong>Quote #QT-001 Submitted</strong>
                      <div class="text-muted small">Electronics Components</div>
                    </div>
                    <span class="text-muted small">2 days ago</span>
                  </div>
                  <div class="vendor-finance-item">
                    <div>
                      <strong>Quote #QT-005 Won</strong>
                      <div class="text-muted small">Office Supplies</div>
                    </div>
                    <span class="text-muted small">1 week ago</span>
                  </div>
                  <div class="vendor-finance-item">
                    <div>
                      <strong>Quote #QT-003 Lost</strong>
                      <div class="text-muted small">Competitor lower price</div>
                    </div>
                    <span class="text-muted small">2 weeks ago</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Submit Quote Modal -->
    <div class="modal fade" id="submitQuoteModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Submit Quote for Electronics Components</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form class="vendor-needs-validation" novalidate>
              <div class="mb-3">
                <label class="form-label">Quote Amount</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" class="form-control" required step="0.01" />
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Delivery Time</label>
                <div class="input-group">
                  <input type="number" class="form-control" required />
                  <span class="input-group-text">days</span>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Quote Validity</label>
                <div class="input-group">
                  <input type="number" class="form-control" value="30" required />
                  <span class="input-group-text">days</span>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Payment Terms</label>
                <select class="form-select" required>
                  <option value="">Select Payment Terms</option>
                  <option>Net 30</option>
                  <option>Net 60</option>
                  <option>50% Advance, 50% on Delivery</option>
                  <option>100% Advance</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Additional Notes</label>
                <textarea
                  class="form-control"
                  rows="4"
                  placeholder="Include any special terms, conditions, or notes..."
                ></textarea>
              </div>

              <div class="mb-3">
                <label class="form-label">Attachments</label>
                <input type="file" class="form-control" multiple />
                <div class="form-text">
                  Upload quotation document, product specifications, or other relevant files
                </div>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary">Submit Quote</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Vendor JS -->
    <script src="../assets/js/vendor.js"></script>
    <script type="module" src="../assets/js/vendor/rfq/rfq.main.js"></script>
  </body>
</html>
