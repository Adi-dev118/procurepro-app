<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vendor Dashboard - Profile</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Vendor CSS -->
    <link rel="stylesheet" href="../assets/css/vendor.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body>
    <div class="vendor-container">
      <!-- Sidebar -->
      <aside class="vendor-sidebar">
        <div class="vendor-sidebar-header">
          <div class="vendor-logo">
            <i class="bi bi-shop vendor-logo-icon"></i>
            <span class="vendor-logo-text">VendorHub</span>
          </div>
          <button class="vendor-toggle-btn">
            <i class="bi bi-chevron-left"></i>
          </button>
        </div>

        <nav class="vendor-sidebar-menu">
          <ul>
            <li>
              <a href="/vendor/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="vendor-menu-text">Dashboard</span>
              </a>
            </li>
            <li>
              <a href="/vendor/products">
                <i class="bi bi-box-seam"></i>
                <span class="vendor-menu-text">Products</span>
              </a>
            </li>
            <li>
              <a href="/vendor/orders">
                <i class="bi bi-cart-check"></i>
                <span class="vendor-menu-text">Orders</span>
              </a>
            </li>
            <li>
              <a href="/vendor/rfqs">
                <i class="bi bi-chat-left-text"></i>
                <span class="vendor-menu-text">RFQs</span>
              </a>
            </li>
            <li>
              <a href="/vendor/finance">
                <i class="bi bi-credit-card"></i>
                <span class="vendor-menu-text">Finance</span>
              </a>
            </li>
            <li>
              <a href="/vendor/profile" class="active">
                <i class="bi bi-person-circle"></i>
                <span class="vendor-menu-text">Profile</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="vendor-sidebar-footer">
          <p><%=name%></p>
          <small>Vendor Account</small>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="vendor-mobile-overlay"></div>

      <!-- Main Content -->
      <main class="vendor-main-content">
        <!-- Topbar -->
        <header class="vendor-topbar">
          <button class="vendor-mobile-menu-btn">
            <i class="bi bi-list"></i>
          </button>

          <h1 class="vendor-page-title">Company Profile</h1>

          <div class="vendor-topbar-actions">
            <div class="vendor-search-box">
              <i class="bi bi-search"></i>
              <input type="text" placeholder="Search..." />
            </div>

            <div class="vendor-notification-badge">
              <i class="bi bi-bell"></i>
              <span>3</span>
            </div>

            <div class="vendor-user-profile" id="profileTrigger">
              <div class="vendor-user-avatar">
                <span><%= name.split(' ').map(word => word[0]).join('').toUpperCase() %></span>
              </div>
              <span class="vendor-user-name"><%=name%></span>
              <i class="bi bi-chevron-down" id="profileChevron"></i>
            </div>

            <!-- Profile Dropdown -->
            <div class="vendor-profile-dropdown" id="profileDropdown">
              <div class="vendor-profile-dropdown-header">
                <div class="vendor-profile-dropdown-avatar">
                  <span><%= name.split(' ').map(word => word[0]).join('').toUpperCase() %></span>
                </div>
                <div class="vendor-profile-dropdown-info">
                  <strong><%=name%></strong>
                  <small><%=email%></small>
                </div>
              </div>
              <div class="vendor-profile-dropdown-divider"></div>
              <a href="/company/login" class="vendor-profile-dropdown-signout" id="signoutButton">
                <i class="bi bi-box-arrow-right"></i>
                Sign Out
              </a>
            </div>
          </div>
        </header>

        <!-- Content Wrapper -->
        <div class="vendor-content-wrapper vendor-profile-page">
          <!-- Profile Header -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <div class="d-flex align-items-center">
                <div
                  class="vendor-user-avatar me-3"
                  style="width: 80px; height: 80px; font-size: 32px"
                >
                  <%= name.split(' ').map(word => word[0]).join('').toUpperCase() %>
                </div>
                <div>
                  <h2 class="vendor-section-title mb-1"><%=name%></h2>
                  <p class="text-muted mb-0">
                    <%=supplier.type%> • Member since <%=supplier.year_established%>
                  </p>
                  <div class="mt-2">
                    <% if(supplier.status === 'approved'){ %>
                    <span class="vendor-status-badge active me-2">Verified</span>

                    <% } else if(supplier.status === 'pending'){ %>
                    <span class="vendor-status-badge pending me-2">Pending</span>

                    <% } else if(supplier.status === 'suspended'){ %>
                    <span class="vendor-status-badge cancelled me-2">Suspended</span>

                    <% } %>

                    <span class="text-warning"
                      ><%=rating.avgRating%>
                      ★ (<%=rating.totalReviews%>)</span
                    >
                  </div>
                </div>
              </div>
              <button class="btn btn-primary">
                <i class="bi bi-pencil me-2"></i>
                Edit Profile
              </button>
            </div>
          </div>

          <!-- Company Profile -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <h3 class="vendor-profile-title">Company Profile</h3>
              <button class="btn btn-outline-primary btn-sm">Edit</button>
            </div>
            <div class="vendor-profile-content">
              <div class="vendor-profile-grid">
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Company Name</div>
                  <div class="vendor-profile-value"><%=supplier.name%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Business Type</div>
                  <div class="vendor-profile-value"><%=supplier.type%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Tax ID</div>
                  <div class="vendor-profile-value"><%=supplier.tax_id%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Business Registration</div>
                  <div class="vendor-profile-value"><%=supplier.business_registration%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Year Established</div>
                  <div class="vendor-profile-value"><%=supplier.year_established%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Number of Employees</div>
                  <div class="vendor-profile-value"><%=supplier.employee_count%></div>
                </div>
              </div>
              <div class="mt-4">
                <div class="vendor-profile-label">Company Description</div>
                <div class="vendor-profile-value mt-2"><%=supplier.description%></div>
              </div>
            </div>
          </div>

          <!-- Contact Information -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <h3 class="vendor-profile-title">Contact Information</h3>
              <button class="btn btn-outline-primary btn-sm">Edit</button>
            </div>
            <div class="vendor-profile-content">
              <div class="vendor-profile-grid">
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Contact Person</div>
                  <div class="vendor-profile-value"><%=contact.contact%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Email Address</div>
                  <div class="vendor-profile-value"><%=contact.email%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Phone Number</div>
                  <div class="vendor-profile-value"><%=contact.mobile_no%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Website</div>
                  <div class="vendor-profile-value"><%=contact.website%></div>
                </div>
              </div>
              <div class="mt-4">
                <div class="vendor-profile-label">Business Address</div>
                <div class="vendor-profile-value mt-2">
                  <%= contact.address_line1 %><br />

                  <% if(contact.address_line2){ %>
                  <%= contact.address_line2 %><br />
                  <% } %>

                  <%= contact.city %>,
                  <%= contact.state %>
                  <%= contact.pincode %><br />
                  <%= contact.country %>
                </div>
              </div>
            </div>
          </div>

          <!-- Team Members -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <h3 class="vendor-profile-title">Team Members</h3>
              <button
                class="btn btn-primary btn-sm"
                data-bs-toggle="modal"
                data-bs-target="#addTeamMemberModal"
              >
                <i class="bi bi-plus-circle me-1"></i> Add Member
              </button>
            </div>
            <div class="vendor-profile-content">
              <div class="vendor-table-responsive">
                <table class="vendor-table">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Role</th>
                      <th>Permissions</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% teamMembers.forEach(member => { %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <div
                            class="vendor-user-avatar me-2"
                            style="width: 30px; height: 30px; font-size: 12px"
                          >
                            <%= member.name.split(' ').map(n => n[0]).join('').toUpperCase() %>
                          </div>

                          <%= member.name %>
                        </div>
                      </td>

                      <td><%= member.email %></td>

                      <td>
                        <span
                          class="badge <%= member.role === 'Admin' ? 'bg-primary' : member.role === 'Support' ? 'bg-warning' : member.role === 'Inventory' ? 'bg-info' : 'bg-secondary' %>"
                        >
                          <%= member.role %>
                        </span>
                      </td>

                      <td><%= member.permissions %></td>

                      <td>
                        <span
                          class="vendor-status-badge <%= member.status === 'active' ? 'active' : 'inactive' %>"
                        >
                          <%= member.status %>
                        </span>
                      </td>

                      <td>
                        <div class="vendor-action-buttons">
                          <button class="vendor-btn-icon edit">
                            <i class="bi bi-pencil"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Warehouse & Logistics -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <h3 class="vendor-profile-title">Warehouse & Logistics Information</h3>
              <button class="btn btn-outline-primary btn-sm">Edit</button>
            </div>
            <div class="vendor-profile-content">
              <div class="vendor-profile-grid">
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Primary Warehouse</div>
                  <div class="vendor-profile-value"><%= logistics.primary_warehouse %></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Warehouse Size</div>
                  <div class="vendor-profile-value"><%= logistics.warehouse_size %></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Shipping Carriers</div>
                  <div class="vendor-profile-value"><%= logistics.shipping_carriers %></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Processing Time</div>
                  <div class="vendor-profile-value"><%= logistics.processing_time %></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Shipping Regions</div>
                  <div class="vendor-profile-value"><%= logistics.shipping_regions %></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Return Policy</div>
                  <div class="vendor-profile-value"><%= logistics.return_policy %></div>
                </div>
              </div>
              <div class="mt-4">
                <div class="vendor-profile-label">Additional Warehouses</div>
                <ul>
                  <% logistics.additional_warehouses.split(',').forEach(w => { %>
                  <li><%= w.trim() %></li>
                  <% }) %>
                </ul>
              </div>
            </div>
          </div>

          <!-- Bank & Payment Details -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <h3 class="vendor-profile-title">Bank & Payment Details</h3>
              <button class="btn btn-outline-primary btn-sm">Edit</button>
            </div>
            <div class="vendor-profile-content">
              <div class="vendor-profile-grid">
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Bank Name</div>
                  <div class="vendor-profile-value"><%=bank.bank_name%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Account Holder</div>
                  <div class="vendor-profile-value"><%=bank.account_holder%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Account Number</div>
                  <div class="vendor-profile-value">
                    **** **** **** <%= bank.account_number.slice(-4) %>
                  </div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Routing Number</div>
                  <div class="vendor-profile-value">******<%= bank.routing_number.slice(-3) %></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">SWIFT Code</div>
                  <div class="vendor-profile-value"><%=bank.swift_code%></div>
                </div>
                <div class="vendor-profile-field">
                  <div class="vendor-profile-label">Payment Methods</div>
                  <div class="vendor-profile-value"><%=bank.payment_methods%></div>
                </div>
              </div>
              <div class="alert alert-info mt-4">
                <i class="bi bi-shield-check me-2"></i>
                Your banking information is securely encrypted and stored. Only the last 4 digits of
                your account number are displayed.
              </div>
            </div>
          </div>

          <!-- Account Settings -->
          <div class="vendor-profile-section">
            <div class="vendor-profile-header">
              <h3 class="vendor-profile-title">Account Settings</h3>
            </div>
            <div class="vendor-profile-content">
              <div class="row">
                <div class="col-md-6">
                  <div class="mb-4">
                    <h5>Security Settings</h5>
                    <div class="form-check mb-3">
                      <input class="form-check-input" type="checkbox" id="twoFactorAuth" />
                      <label class="form-check-label" for="twoFactorAuth">
                        Enable Two-Factor Authentication
                      </label>
                    </div>
                    <div class="form-check mb-3">
                      <input class="form-check-input" type="checkbox" id="loginAlerts" checked />
                      <label class="form-check-label" for="loginAlerts">
                        Receive login alerts
                      </label>
                    </div>
                    <button class="btn btn-outline-primary btn-sm">
                      <i class="bi bi-key me-1"></i> Change Password
                    </button>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-4">
                    <h5>Notification Preferences</h5>
                    <div class="form-check mb-3">
                      <input class="form-check-input" type="checkbox" id="emailOrders" checked />
                      <label class="form-check-label" for="emailOrders">
                        Email for new orders
                      </label>
                    </div>
                    <div class="form-check mb-3">
                      <input class="form-check-input" type="checkbox" id="emailRFQs" checked />
                      <label class="form-check-label" for="emailRFQs"> Email for new RFQs </label>
                    </div>
                    <div class="form-check mb-3">
                      <input class="form-check-input" type="checkbox" id="emailPayments" checked />
                      <label class="form-check-label" for="emailPayments">
                        Email for payments
                      </label>
                    </div>
                  </div>
                </div>
              </div>

              <div class="mt-4">
                <h5>Account Actions</h5>
                <div class="d-flex gap-2 mt-3">
                  <button class="btn btn-outline-secondary">
                    <i class="bi bi-download me-2"></i> Export Account Data
                  </button>
                  <button class="btn btn-outline-danger">
                    <i class="bi bi-trash me-2"></i> Deactivate Account
                  </button>
                </div>
                <div class="alert alert-warning mt-3">
                  <i class="bi bi-exclamation-triangle me-2"></i>
                  Deactivating your account will hide your products and stop new orders. You can
                  reactivate anytime.
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Add Team Member Modal -->
    <div class="modal fade" id="addTeamMemberModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Add Team Member</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form class="vendor-needs-validation" novalidate>
              <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" class="form-control" required />
              </div>

              <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input type="email" class="form-control" required />
              </div>

              <div class="mb-3">
                <label class="form-label">Role</label>
                <select class="form-select" required>
                  <option value="">Select Role</option>
                  <option>Admin</option>
                  <option>Support</option>
                  <option>Inventory Manager</option>
                  <option>Finance</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Permissions</label>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permProducts" />
                  <label class="form-check-label" for="permProducts"> Manage Products </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permOrders" />
                  <label class="form-check-label" for="permOrders"> Manage Orders </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permFinance" />
                  <label class="form-check-label" for="permFinance"> View Finance </label>
                </div>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary">Add Member</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Vendor JS -->
    <script src="../assets/js/vendor.js"></script>
  </body>
</html>
