<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ProcurePro — RFQ Created</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/css/company-style.css" />
    <style>
      :root {
        --col-bg: #eef2f9;
        --col-surface: #f7f9fd;
        --col-surface-2: #edf1f8;
        --col-border: #cdd8ee;
        --col-border-strong: #b3c3e0;
        --col-text-primary: #0f1e3d;
        --col-text-secondary: #3d5070;
        --col-text-muted: #7a90b8;
        --col-accent: #1d6bf3;
        --col-accent-light: #dce8fd;
        --col-accent-hover: #1558d6;
        --col-success: #0f9960;
        --col-success-light: #d6f0e6;
        --col-warning: #b45309;
        --col-warning-light: #fef3d9;
        --col-danger: #dc2626;
        --col-danger-light: #fde8e8;
        --col-purple: #5b21b6;
        --col-purple-light: #ede9fe;
        --nav-w: 240px;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --radius-xl: 20px;
        --shadow-sm: 0 1px 3px rgba(29, 107, 243, 0.08);
        --shadow-md: 0 4px 16px rgba(29, 107, 243, 0.12);
        --shadow-lg: 0 8px 28px rgba(29, 107, 243, 0.15);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--col-bg);
        color: var(--col-text-primary);
        min-height: 100vh;
        font-size: 14px;
        line-height: 1.6;
      }

      /* ── Layout Shell ── */
      .shell {
        display: flex;
        min-height: 100vh;
      }

      /* ── Sidebar ── */
      .sidebar {
        width: var(--nav-w);
        background: #0f1e3d;
        border-right: 1px solid #1a3060;
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        transition: transform 0.25s ease;
      }
      .sidebar-logo {
        padding: 24px 20px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .logo-mark {
        width: 34px;
        height: 34px;
        background: var(--col-accent);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        font-weight: 700;
        flex-shrink: 0;
      }
      .logo-name {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        letter-spacing: -0.3px;
      }
      .logo-badge {
        font-size: 10px;
        color: var(--col-accent);
        background: var(--col-accent-light);
        padding: 1px 6px;
        border-radius: 20px;
        font-weight: 600;
        margin-top: 1px;
      }
      .sidebar-section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        padding: 18px 20px 6px;
      }
      .sidebar-nav {
        overflow-y: auto;
        scroll-behavior: smooth;
        flex: 1;
        padding: 8px 14px;
      }
      .sidebar-nav::-webkit-scrollbar {
        width: 0;
      }
      .sidebar-nav:hover::-webkit-scrollbar {
        width: 6px;
      }
      .sidebar-nav:hover::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.25);
        border-radius: 10px;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: var(--radius-sm);
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        font-weight: 500;
        font-size: 13.5px;
        transition: all 0.15s;
        margin-bottom: 2px;
        cursor: pointer;
      }
      .nav-item i {
        font-size: 15px;
        width: 18px;
        text-align: center;
        flex-shrink: 0;
      }
      .nav-item:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
      }
      .nav-item.active {
        background: rgba(29, 107, 243, 0.25);
        color: #fff;
        font-weight: 600;
      }
      .nav-item.active i {
        color: #5ba4fb;
      }
      .nav-badge {
        margin-left: auto;
        background: var(--col-danger);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 20px;
        min-width: 18px;
        text-align: center;
      }

      .sidebar-footer {
        padding: 16px 14px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
      .user-card {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.07);
        cursor: pointer;
        transition: background 0.15s;
      }
      .user-card:hover {
        background: rgba(255, 255, 255, 0.12);
      }
      .user-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--col-accent);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 12px;
        flex-shrink: 0;
      }
      .user-name {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.2;
        color: #fff;
      }
      .user-role {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.45);
      }
      .user-card > i {
        margin-left: auto;
        color: rgba(255, 255, 255, 0.35);
        font-size: 13px;
      }

      /* ── Main ── */
      .main {
        margin-left: var(--nav-w);
        flex: 1;
        min-height: 100vh;
      }

      /* ── Top Bar ── */
      .topbar {
        background: #f7f9fd;
        border-bottom: 1px solid #cdd8ee;
        height: 60px;
        display: flex;
        align-items: center;
        padding: 0 28px;
        gap: 16px;
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: 0 1px 4px rgba(29, 107, 243, 0.07);
      }
      .topbar-title {
        font-size: 15px;
        font-weight: 600;
        flex: 1;
      }
      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .icon-btn {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--col-border);
        background: var(--col-surface);
        color: var(--col-text-secondary);
        cursor: pointer;
        transition: all 0.15s;
        position: relative;
      }
      .icon-btn:hover {
        background: var(--col-bg);
        color: var(--col-text-primary);
      }
      .icon-btn .dot {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--col-danger);
        border: 1.5px solid var(--col-surface);
      }
      .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--col-text-muted);
      }
      .breadcrumb-nav a {
        color: var(--col-text-muted);
        text-decoration: none;
        transition: color 0.15s;
      }
      .breadcrumb-nav a:hover {
        color: var(--col-accent);
      }
      .breadcrumb-nav .sep {
        font-size: 11px;
      }
      .breadcrumb-nav .current {
        color: var(--col-text-primary);
        font-weight: 600;
      }

      /* ── Page Content ── */
      .page-content {
        padding: 28px;
        max-width: 1000px;
      }

      /* ── Success Banner ── */
      .success-banner {
        background: linear-gradient(135deg, #064e2e 0%, #0a7a48 60%, #0f9960 100%);
        border-radius: var(--radius-xl);
        padding: 32px 36px;
        color: #fff;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 24px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 6px 24px rgba(15, 153, 96, 0.25);
        animation: slideDown 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      .success-banner::before {
        content: '';
        position: absolute;
        right: -40px;
        top: -60px;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.06);
        pointer-events: none;
      }
      .success-banner::after {
        content: '';
        position: absolute;
        right: 60px;
        bottom: -80px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        pointer-events: none;
      }
      .success-icon-wrap {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 28px;
        position: relative;
        z-index: 1;
        border: 2px solid rgba(255, 255, 255, 0.25);
      }
      .success-banner-text {
        position: relative;
        z-index: 1;
        flex: 1;
      }
      .sb-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 4px;
      }
      .sb-heading {
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.4px;
        margin-bottom: 4px;
      }
      .sb-sub {
        font-size: 13.5px;
        color: rgba(255, 255, 255, 0.65);
      }
      .sb-rfq-id {
        font-family: 'DM Mono', monospace;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-sm);
        padding: 3px 10px;
        font-size: 13px;
        font-weight: 500;
        display: inline-block;
        margin-top: 8px;
        color: #fff;
      }
      .success-banner-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: relative;
        z-index: 1;
      }
      .btn-success-outline {
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: var(--radius-sm);
        padding: 9px 18px;
        font-family: inherit;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: all 0.15s;
        white-space: nowrap;
        text-decoration: none;
      }
      .btn-success-outline:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
      }

      /* ── Section Card ── */
      .section-card {
        background: var(--col-surface);
        border: 1px solid var(--col-border);
        border-radius: var(--radius-lg);
        margin-bottom: 20px;
        overflow: hidden;
        animation: fadeUp 0.4s ease both;
      }
      .section-card:nth-child(2) {
        animation-delay: 0.08s;
      }
      .section-card:nth-child(3) {
        animation-delay: 0.14s;
      }
      .section-card:nth-child(4) {
        animation-delay: 0.2s;
      }

      .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 22px;
        border-bottom: 1px solid var(--col-border);
      }
      .section-title {
        font-size: 14.5px;
        font-weight: 700;
        color: var(--col-text-primary);
      }
      .section-subtitle {
        font-size: 12.5px;
        color: var(--col-text-muted);
        margin-top: 1px;
      }

      /* ── Detail Grid ── */
      .detail-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
      }
      .detail-item {
        padding: 18px 22px;
        border-right: 1px solid var(--col-border);
        border-bottom: 1px solid var(--col-border);
      }
      .detail-item:nth-child(3n) {
        border-right: none;
      }
      .detail-item:nth-last-child(-n + 3) {
        border-bottom: none;
      }
      .detail-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--col-text-muted);
        margin-bottom: 5px;
      }
      .detail-value {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--col-text-primary);
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .detail-value.mono {
        font-family: 'DM Mono', monospace;
        font-size: 13.5px;
      }

      /* ── Status Badge ── */
      .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.2px;
      }
      .status-badge.active {
        background: var(--col-success-light);
        color: var(--col-success);
      }
      .status-badge.active::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--col-success);
        display: inline-block;
      }
      .status-badge.pending {
        background: var(--col-warning-light);
        color: var(--col-warning);
      }

      /* ── Priority Badge ── */
      .priority-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
      }
      .priority-badge.high {
        background: var(--col-danger-light);
        color: var(--col-danger);
      }
      .priority-badge.medium {
        background: var(--col-warning-light);
        color: var(--col-warning);
      }
      .priority-badge.low {
        background: var(--col-success-light);
        color: var(--col-success);
      }

      /* ── Items Table ── */
      .items-table-wrap {
        overflow-x: auto;
      }
      .items-table {
        width: 100%;
        border-collapse: collapse;
      }
      .items-table thead tr {
        background: var(--col-surface-2);
      }
      .items-table th {
        padding: 10px 18px;
        font-size: 11.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--col-text-muted);
        text-align: left;
        border-bottom: 1px solid var(--col-border);
      }
      .items-table td {
        padding: 13px 18px;
        font-size: 13.5px;
        border-bottom: 1px solid var(--col-border);
        color: var(--col-text-secondary);
        vertical-align: middle;
      }
      .items-table tr:last-child td {
        border-bottom: none;
      }
      .items-table tr:hover td {
        background: var(--col-surface-2);
      }
      .item-num {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--col-accent-light);
        color: var(--col-accent);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
      }
      .product-name {
        font-weight: 600;
        color: var(--col-text-primary);
      }

      /* ── Specs Table ── */
      .specs-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
      }
      .spec-item {
        padding: 12px 22px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border-bottom: 1px solid var(--col-border);
        border-right: 1px solid var(--col-border);
      }
      .spec-item:nth-child(2n) {
        border-right: none;
      }
      .spec-item:nth-last-child(-n + 2) {
        border-bottom: none;
      }
      /* handle odd last item */
      .spec-item:last-child:nth-child(odd) {
        border-right: none;
        grid-column: span 2;
      }
      .spec-icon {
        width: 32px;
        height: 32px;
        background: var(--col-accent-light);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--col-accent);
        font-size: 14px;
        flex-shrink: 0;
      }
      .spec-name {
        font-size: 11.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--col-text-muted);
        margin-bottom: 2px;
      }
      .spec-value {
        font-size: 13.5px;
        font-weight: 500;
        color: var(--col-text-primary);
      }

      /* ── Budget Card ── */
      .budget-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 22px;
      }
      .budget-block {
        flex: 1;
      }
      .budget-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--col-text-muted);
        margin-bottom: 4px;
      }
      .budget-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--col-text-primary);
        letter-spacing: -0.5px;
      }
      .budget-divider {
        font-size: 22px;
        color: var(--col-border-strong);
        font-weight: 300;
      }
      .budget-range-bar {
        flex: 2;
        background: var(--col-bg);
        border-radius: 20px;
        height: 8px;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--col-border);
      }
      .budget-range-fill {
        position: absolute;
        top: 0;
        left: 10%;
        right: 10%;
        height: 100%;
        background: linear-gradient(90deg, var(--col-accent-light), var(--col-accent));
        border-radius: 20px;
      }

      /* ── Action Footer ── */
      .action-footer {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 20px 22px;
        border-top: 1px solid var(--col-border);
        background: var(--col-surface-2);
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }
      .btn-primary {
        background: var(--col-accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 10px 20px;
        font-family: inherit;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.15s;
        text-decoration: none;
      }
      .btn-primary:hover {
        background: var(--col-accent-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: #fff;
      }
      .btn-outline {
        background: var(--col-surface);
        color: var(--col-text-secondary);
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        padding: 10px 20px;
        font-family: inherit;
        font-size: 13.5px;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.15s;
        text-decoration: none;
      }
      .btn-outline:hover {
        border-color: var(--col-border-strong);
        color: var(--col-text-primary);
        background: var(--col-bg);
      }
      .btn-outline.danger {
        color: var(--col-danger);
      }
      .btn-outline.danger:hover {
        border-color: var(--col-danger);
        background: var(--col-danger-light);
      }

      /* ── Empty state ── */
      .empty-state {
        padding: 28px 22px;
        text-align: center;
        color: var(--col-text-muted);
        font-size: 13.5px;
      }
      .empty-state i {
        font-size: 28px;
        display: block;
        margin-bottom: 8px;
        color: var(--col-border-strong);
      }

      /* ── Animations ── */
      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── Responsive ── */
      @media (max-width: 900px) {
        .main {
          margin-left: 0;
        }
        .sidebar {
          transform: translateX(-100%);
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .detail-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .specs-grid {
          grid-template-columns: 1fr;
        }
        .spec-item {
          border-right: none !important;
        }
        .spec-item:last-child {
          border-bottom: none;
        }
        .success-banner {
          flex-direction: column;
          gap: 16px;
        }
        .success-banner-actions {
          flex-direction: row;
          flex-wrap: wrap;
        }
        .budget-row {
          flex-wrap: wrap;
        }
      }
      @media (max-width: 600px) {
        .page-content {
          padding: 16px;
        }
        .detail-grid {
          grid-template-columns: 1fr 1fr;
        }
        .items-table th,
        .items-table td {
          padding: 10px 12px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <!-- ── Sidebar ── -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
          <div class="logo-mark">P</div>
          <div>
            <div class="logo-name">ProcurePro</div>
            <div class="logo-badge">Buyer</div>
          </div>
        </div>

        <nav class="sidebar-nav">
          <div class="sidebar-section-label">Main</div>
          <a href="/dashboard" class="nav-item"><i class="bi bi-grid-1x2"></i> Dashboard</a>
          <a href="/marketplace" class="nav-item"><i class="bi bi-shop"></i> Marketplace</a>
          <a href="/rfq" class="nav-item active"
            ><i class="bi bi-megaphone"></i> My RFQs <span class="nav-badge">3</span></a
          >
          <a href="/quotes" class="nav-item"><i class="bi bi-file-earmark-text"></i> Quotations</a>
          <a href="/orders" class="nav-item"><i class="bi bi-cart-check"></i> Orders</a>

          <div class="sidebar-section-label">Manage</div>
          <a href="/suppliers" class="nav-item"><i class="bi bi-people"></i> Suppliers</a>
          <a href="/invoices" class="nav-item"><i class="bi bi-receipt"></i> Invoices</a>
          <a href="/reports" class="nav-item"><i class="bi bi-bar-chart-line"></i> Reports</a>

          <div class="sidebar-section-label">Account</div>
          <a href="/settings" class="nav-item"><i class="bi bi-gear"></i> Settings</a>
          <a href="/help" class="nav-item"><i class="bi bi-question-circle"></i> Help & Support</a>
        </nav>

        <div class="sidebar-footer">
          <div class="user-card" id="userCard">
            <div class="user-avatar">
              <%= typeof user !== 'undefined' ? user.name.charAt(0).toUpperCase() : 'B' %>
            </div>
            <div>
              <div class="user-name"><%= typeof user !== 'undefined' ? user.name : 'Buyer' %></div>
              <div class="user-role">Buyer Account</div>
            </div>
            <i class="bi bi-chevron-up user-chevron"></i>
          </div>
        </div>
      </aside>

      <!-- ── Main ── -->
      <div class="main">
        <!-- Top Bar -->
        <header class="topbar">
          <button class="icon-btn d-md-none" id="menuToggle" style="border: none">
            <i class="bi bi-list" style="font-size: 18px"></i>
          </button>
          <nav class="breadcrumb-nav">
            <a href="/dashboard">Dashboard</a>
            <span class="sep"><i class="bi bi-chevron-right" style="font-size: 10px"></i></span>
            <a href="/rfq">RFQs</a>
            <span class="sep"><i class="bi bi-chevron-right" style="font-size: 10px"></i></span>
            <span class="current">RFQ #<%= rfq.rfqId %></span>
          </nav>
          <div class="topbar-actions ms-auto">
            <div class="icon-btn" title="Notifications">
              <i class="bi bi-bell" style="font-size: 15px"></i>
              <span class="dot"></span>
            </div>
            <div class="icon-btn" title="Help">
              <i class="bi bi-question-circle" style="font-size: 15px"></i>
            </div>
          </div>
        </header>

        <!-- Page Content -->
        <div class="page-content">
          <!-- ── Success Banner ── -->
          <div class="success-banner">
            <div class="success-icon-wrap">
              <i class="bi bi-check2-circle"></i>
            </div>
            <div class="success-banner-text">
              <div class="sb-label">Request for Quotation</div>
              <div class="sb-heading">RFQ Published Successfully!</div>
              <div class="sb-sub">
                Your RFQ is now live and visible to matched suppliers. You'll receive quotations
                soon.
              </div>
              <div class="sb-rfq-id"><i class="bi bi-hash"></i> RFQ-<%= rfq.rfqId %></div>
            </div>
            <div class="success-banner-actions">
              <a href="/rfq" class="btn-success-outline">
                <i class="bi bi-list-ul"></i> All RFQs
              </a>
              <a href="/rfq/create" class="btn-success-outline">
                <i class="bi bi-plus-circle"></i> New RFQ
              </a>
            </div>
          </div>

          <!-- ── RFQ Overview ── -->
          <div class="section-card">
            <div class="section-header">
              <div>
                <div class="section-title">
                  <i
                    class="bi bi-info-circle"
                    style="color: var(--col-accent); margin-right: 6px"
                  ></i
                  >RFQ Overview
                </div>
                <div class="section-subtitle">Core details of your request</div>
              </div>
              <span class="status-badge active">Active</span>
            </div>

            <div class="detail-grid">
              <div class="detail-item">
                <div class="detail-label">RFQ ID</div>
                <div class="detail-value mono">
                  <i class="bi bi-hash" style="color: var(--col-text-muted)"></i
                  >RFQ-<%= rfq.rfqId %>
                </div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Title</div>
                <div class="detail-value"><%= rfq.title %></div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Category</div>
                <div class="detail-value">
                  <i class="bi bi-tag" style="color: var(--col-accent)"></i
                  ><%= rfq.category || ('Category #' + rfq.categoryId) %>
                </div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Total Quantity</div>
                <div class="detail-value">
                  <i class="bi bi-boxes" style="color: var(--col-text-muted)"></i
                  ><%= rfq.totalQuantity.toLocaleString() %>
                  units
                </div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Deadline</div>
                <div class="detail-value">
                  <i class="bi bi-calendar-event" style="color: var(--col-warning)"></i
                  ><%= new Date(rfq.deadline).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                </div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Location</div>
                <div class="detail-value">
                  <i class="bi bi-geo-alt" style="color: var(--col-danger)"></i
                  ><%= rfq.location %>
                </div>
              </div>
              <div
                class="detail-item"
                style="grid-column: span 2; border-right: 1px solid var(--col-border)"
              >
                <div class="detail-label">Description</div>
                <div
                  class="detail-value"
                  style="font-weight: 400; font-size: 13.5px; line-height: 1.6; display: block"
                >
                  <%= rfq.description %>
                </div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Priority</div>
                <div class="detail-value">
                  <% const p = (rfq.priority || '').toLowerCase(); %>
                  <span
                    class="priority-badge <%= p === 'high' ? 'high' : p === 'medium' ? 'medium' : 'low' %>"
                  >
                    <i
                      class="bi bi-<%= p === 'high' ? 'arrow-up-circle-fill' : p === 'medium' ? 'dash-circle-fill' : 'arrow-down-circle-fill' %>"
                    ></i>
                    <%= rfq.priority.charAt(0).toUpperCase() + rfq.priority.slice(1) %>
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Budget ── -->
          <div class="section-card">
            <div class="section-header">
              <div>
                <div class="section-title">
                  <i
                    class="bi bi-currency-dollar"
                    style="color: var(--col-success); margin-right: 6px"
                  ></i
                  >Budget Range
                </div>
                <div class="section-subtitle">Your acceptable price window</div>
              </div>
            </div>
            <div class="budget-row">
              <div class="budget-block">
                <div class="budget-label">Minimum Budget</div>
                <div class="budget-value" style="color: var(--col-success)">
                  ₹<%= Number(rfq.budgetMin).toLocaleString('en-IN') %>
                </div>
              </div>
              <div class="budget-divider">—</div>
              <div class="budget-block">
                <div class="budget-label">Maximum Budget</div>
                <div class="budget-value" style="color: var(--col-accent)">
                  ₹<%= Number(rfq.budgetMax).toLocaleString('en-IN') %>
                </div>
              </div>
              <div class="budget-range-bar" title="Budget range visualization">
                <div class="budget-range-fill"></div>
              </div>
            </div>
          </div>

          <!-- ── Items ── -->
          <div class="section-card">
            <div class="section-header">
              <div>
                <div class="section-title">
                  <i class="bi bi-box-seam" style="color: var(--col-purple); margin-right: 6px"></i
                  >Requested Items
                </div>
                <div class="section-subtitle">
                  <%= rfq.items ? rfq.items.length : 0 %> item(s) in this RFQ
                </div>
              </div>
            </div>
            <% if (rfq.items && rfq.items.length > 0) { %>
            <div class="items-table-wrap">
              <table class="items-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Quantity</th>
                  </tr>
                </thead>
                <tbody>
                  <% rfq.items.forEach(function(item, idx) { %>
                  <tr>
                    <td><span class="item-num"><%= idx + 1 %></span></td>
                    <td class="product-name"><%= item.productName %></td>
                    <td>
                      <strong><%= Number(item.quantity).toLocaleString() %></strong>
                      <span style="color: var(--col-text-muted); font-size: 12px">units</span>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
            <% } else { %>
            <div class="empty-state">
              <i class="bi bi-box"></i>
              No items listed for this RFQ.
            </div>
            <% } %>
          </div>

          <!-- ── Specifications ── -->
          <% if (rfq.specifications && rfq.specifications.length > 0) { %>
          <div class="section-card">
            <div class="section-header">
              <div>
                <div class="section-title">
                  <i class="bi bi-sliders" style="color: var(--col-warning); margin-right: 6px"></i
                  >Specifications
                </div>
                <div class="section-subtitle">
                  <%= rfq.specifications.length %> specification(s) defined
                </div>
              </div>
            </div>
            <div class="specs-grid">
              <% rfq.specifications.forEach(function(spec) { %>
              <div class="spec-item">
                <div class="spec-icon"><i class="bi bi-ui-checks-grid"></i></div>
                <div>
                  <div class="spec-name"><%= spec.specName %></div>
                  <div class="spec-value"><%= spec.specValue %></div>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
          <% } %>

          <!-- ── Action Footer ── -->
          <div class="section-card" style="margin-bottom: 0">
            <div class="action-footer">
              <a href="/rfq/<%= rfq.rfqId %>/quotes" class="btn-primary">
                <i class="bi bi-collection"></i> View Incoming Quotes
              </a>
              <a href="/rfq/<%= rfq.rfqId %>/edit" class="btn-outline">
                <i class="bi bi-pencil"></i> Edit RFQ
              </a>
              <a href="/rfq" class="btn-outline"> <i class="bi bi-list-ul"></i> Back to RFQs </a>
              <a href="/rfq/<%= rfq.rfqId %>/close" class="btn-outline danger ms-auto">
                <i class="bi bi-x-circle"></i> Close RFQ
              </a>
            </div>
          </div>
        </div>
        <!-- /page-content -->
      </div>
      <!-- /main -->
    </div>
    <!-- /shell -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Sidebar toggle (mobile)
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      if (menuToggle) {
        menuToggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
          if (!sidebar.contains(e.target) && !menuToggle.contains(e.target)) {
            sidebar.classList.remove('open');
          }
        });
      }
    </script>
  </body>
</html>
