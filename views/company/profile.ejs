    <script>
      const menuToggle = document.getElementById('menuToggle'),
        sidebar = document.getElementById('sidebar');
      if (menuToggle) {
        menuToggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
          if (!sidebar.contains(e.target) && !menuToggle.contains(e.target))
            sidebar.classList.remove('open');
        });
      }
      const tabs = ['account', 'company', 'payment', 'team', 'security', 'preferences'];
      document.querySelectorAll('.side-tab-item').forEach((item) => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          document.querySelectorAll('.side-tab-item').forEach((t) => t.classList.remove('active'));
          item.classList.add('active');
          tabs.forEach((t) => {
            const el = document.getElementById('tab-' + t);
            if (el) el.style.display = 'none';
          });
          const el = document.getElementById('tab-' + item.dataset.tab);
          if (el) el.style.display = 'block';
        });
      });
    </script>
