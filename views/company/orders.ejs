<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orders - ProcurePro</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Shared CSS -->
    <link rel="stylesheet" href="../assets/css/style.css" />

    <!-- Company CSS -->
    <link rel="stylesheet" href="../assets/css/company-style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body class="company-dashboard">
    <!-- Header (Same as dashboard) -->
    <header class="company-header">
      <div class="container-fluid d-flex justify-content-between align-items-center">
        <div class="company-logo">
          <i class="bi bi-building"></i>
          <span>ProcurePro</span>
        </div>

        <button class="mobile-menu-btn d-lg-none">
          <i class="bi bi-list"></i>
        </button>

        <nav class="company-nav d-none d-lg-flex">
          <a href="/dashboard" class="company-nav-link">
            <i class="bi bi-speedometer2 me-1"></i> Dashboard
          </a>
          <a href="/marketplace" class="company-nav-link">
            <i class="bi bi-shop me-1"></i> Marketplace
          </a>
          <a href="/rfq" class="company-nav-link">
            <i class="bi bi-megaphone me-1"></i> RFQ Center
          </a>
          <a href="/orders" class="company-nav-link active">
            <i class="bi bi-cart-check me-1"></i> Orders
          </a>
          <a href="/profile" class="company-nav-link">
            <i class="bi bi-person-circle me-1"></i> Profile
          </a>
        </nav>

        <div class="company-actions">
          <div class="search-box-company d-none d-md-block">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search orders..." />
          </div>

          <button class="notification-btn">
            <i class="bi bi-bell"></i>
            <span class="notification-badge">3</span>
          </button>

          <div class="company-profile">
            <div class="company-avatar"> <%= name.name.split(' ').map(word => word[0]).join('').toUpperCase() %></div>
            <div class="d-none d-md-block">
              <div class="company-name"><%=name.name%></div>
              <div class="text-muted small">Buyer Account</div>
            </div>
            <i class="bi bi-chevron-down"></i>
          </div>
        </div>
      </div>

      <div class="company-nav-mobile d-lg-none">
        <a href="/dashboard" class="company-nav-link">
          <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
        <a href="/marketplace" class="company-nav-link">
          <i class="bi bi-shop me-2"></i> Marketplace
        </a>
        <a href="/rfq" class="company-nav-link">
          <i class="bi bi-megaphone me-2"></i> RFQ Center
        </a>
        <a href="/orders" class="company-nav-link active">
          <i class="bi bi-cart-check me-2"></i> Orders
        </a>
        <a href="/profile" class="company-nav-link">
          <i class="bi bi-person-circle me-2"></i> Profile
        </a>
      </div>

      <div class="mobile-overlay"></div>
    </header>

    <!-- Main Content -->
    <main class="company-main">
      <div class="container-fluid py-4">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <h1 class="h2 mb-1">Orders & Transactions</h1>
            <p class="text-muted mb-0">Track your purchases, invoices, and payments</p>
          </div>
          <div>
            <button class="btn btn-outline-primary">
              <i class="bi bi-download me-2"></i> Export Orders
            </button>
          </div>
        </div>

        <!-- Order Stats -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="card-company p-4">
              <div class="d-flex align-items-center">
                <div class="stats-icon bg-primary me-3">
                  <i class="bi bi-cart"></i>
                </div>
                <div>
                  <h3 class="mb-0"><%=orderStats.totalOrders%></h3>
                  <p class="text-muted mb-0">Total Orders</p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card-company p-4">
              <div class="d-flex align-items-center">
                <div class="stats-icon bg-warning me-3">
                  <i class="bi bi-clock"></i>
                </div>
                <div>
                  <h3 class="mb-0"><%=orderStats.pendingOrders%></h3>
                  <p class="text-muted mb-0">Pending</p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card-company p-4">
              <div class="d-flex align-items-center">
                <div class="stats-icon bg-info me-3">
                  <i class="bi bi-truck"></i>
                </div>
                <div>
                  <h3 class="mb-0"><%=orderStats.inTransitOrders%></h3>
                  <p class="text-muted mb-0">In Transit</p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card-company p-4">
              <div class="d-flex align-items-center">
                <div class="stats-icon bg-success me-3">
                  <i class="bi bi-check-circle"></i>
                </div>
                <div>
                  <h3 class="mb-0"><%=orderStats.completedOrders%></h3>
                  <p class="text-muted mb-0">Completed</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Order Filters -->
        <div class="card-company p-4 mb-4">
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label">Status</label>
              <select class="form-select">
                <option>All Status</option>
                <option>Pending</option>
                <option>Processing</option>
                <option>Shipped</option>
                <option>Delivered</option>
                <option>Cancelled</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Date Range</label>
              <select class="form-select">
                <option>All Time</option>
                <option>Last 7 Days</option>
                <option>Last 30 Days</option>
                <option>Last 90 Days</option>
                <option>This Month</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Supplier</label>
              <select class="form-select">
                <option>All Suppliers</option>
                <option>TechGadgets Ltd</option>
                <option>Global Supplies Inc.</option>
                <option>Precision Parts GmbH</option>
                <option>Valve Factory Italia</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Amount</label>
              <select class="form-select">
                <option>Any Amount</option>
                <option>Under $1,000</option>
                <option>$1,000 - $5,000</option>
                <option>$5,000 - $10,000</option>
                <option>Over $10,000</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Orders Table -->
        <div class="card-company">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead>
                  <tr>
                    <th>Order #</th>
                    <th>Supplier</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% orderHistory.forEach(order => { %>

                  <tr>
                    <td>
                      <strong>#ORD-<%= order.id %></strong>

                      <div class="text-muted small">
                        <% if(order.rfq_id){ %> From RFQ #RFQ-<%= order.rfq_id %> <% } else { %>
                        Direct Purchase <% } %>
                      </div>
                    </td>

                    <td>
                      <div class="d-flex align-items-center">
                        <div class="supplier-avatar me-2">
<%= order.supplier.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase() %>
</div>

                        <div>
                          <div><%= order.supplier %></div>
                          <div class="text-muted small">
                            <%= order.rating ? order.rating : "0.0" %> ★
                          </div>
                        </div>
                      </div>
                    </td>

                    <td>
                      <%= new Date(order.created_at).toISOString().split('T')[0] %>
                    </td>

                    <td>
                      <%= order.items %>
                    </td>

                    <td>
                      <strong>$<%= order.total_amount %></strong>

                      <div class="text-muted small">
                        <%= order.payment_status.charAt(0).toUpperCase() +
                        order.payment_status.slice(1) %>
                      </div>
                    </td>

                    <td>
                      <span
                        class="badge <% if(order.status==='processing'){ %> bg-info <% } else if(order.status==='delivered'){ %> bg-success <% } else if(order.status==='shipped'){ %> bg-warning <% } else if(order.status==='cancelled'){ %> bg-danger <% } else { %> bg-secondary <% } %>"
                      >
                        <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                      </span>
                    </td>

                    <td>
                      <span
                        class="badge <% if(order.payment_status==='completed' || order.payment_status==='paid'){ %> bg-success <% } else if(order.payment_status==='pending'){ %> bg-warning <% } else if(order.payment_status==='refunded'){ %> bg-danger <% } %>"
                      >
                        <%= order.payment_status.charAt(0).toUpperCase() +
                        order.payment_status.slice(1) %>
                      </span>
                    </td>

                    <td>
                      <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-primary">
                          <i class="bi bi-eye"></i>
                        </button>

                        <button class="btn btn-outline-secondary">
                          <i class="bi bi-receipt"></i>
                        </button>

                        <% if(order.status === "processing" || order.status === "shipped"){ %>
                        <button
                          class="btn btn-outline-info track-order-btn"
                          data-order-id="<%= order.id %>"
                        >
                          <i class="bi bi-truck"></i>
                        </button>
                        <% } %>

                        <% if(order.payment_status === "pending"){ %>
                        <button class="btn btn-outline-warning">
                          <i class="bi bi-credit-card"></i>
                        </button>
                        <% } %>
                      </div>
                    </td>
                  </tr>

                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Pagination -->
        <nav class="mt-4">
          <ul class="pagination justify-content-center">
            <li class="page-item disabled">
              <a class="page-link" href="#" tabindex="-1">Previous</a>
            </li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">4</a></li>
            <li class="page-item"><a class="page-link" href="#">5</a></li>
            <li class="page-item">
              <a class="page-link" href="#">Next</a>
            </li>
          </ul>
        </nav>

        <!-- Order Tracking -->
        <div class="row mt-5">
          <div class="col-lg-8">
            <div class="card-company p-4">
              <h4 class="mb-4">Order Tracking - #ORD-7843</h4>
              <div class="order-timeline">
                <div class="timeline-step completed">
                  <div class="timeline-content">
                    <div class="timeline-date">Nov 1, 2023</div>
                    <div class="timeline-title">Order Placed</div>
                    <p class="text-muted mb-0">Order confirmed and payment processed</p>
                  </div>
                </div>
                <div class="timeline-step completed">
                  <div class="timeline-content">
                    <div class="timeline-date">Nov 2, 2023</div>
                    <div class="timeline-title">Order Processed</div>
                    <p class="text-muted mb-0">
                      Supplier confirmed order and prepared for shipment
                    </p>
                  </div>
                </div>
                <div class="timeline-step active">
                  <div class="timeline-content">
                    <div class="timeline-date">Nov 4, 2023</div>
                    <div class="timeline-title">Shipped</div>
                    <p class="text-muted mb-0">
                      <strong>Tracking #:</strong> TRK-789456123<br />
                      <strong>Carrier:</strong> DHL Express<br />
                      <strong>Estimated Delivery:</strong> Nov 8, 2023
                    </p>
                  </div>
                </div>
                <div class="timeline-step">
                  <div class="timeline-content">
                    <div class="timeline-date">Expected Nov 8, 2023</div>
                    <div class="timeline-title">Out for Delivery</div>
                    <p class="text-muted mb-0">Package will be delivered today</p>
                  </div>
                </div>
                <div class="timeline-step">
                  <div class="timeline-content">
                    <div class="timeline-date">--</div>
                    <div class="timeline-title">Delivered</div>
                    <p class="text-muted mb-0">Order delivered successfully</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="card-company p-4">
              <h4 class="mb-4">Invoice Details</h4>
              <div class="invoice-details">
                <div class="d-flex justify-content-between mb-2">
                  <span>Subtotal:</span>
                  <span>$8,000.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                  <span>Shipping:</span>
                  <span>$300.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                  <span>Tax:</span>
                  <span>$150.00</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between mb-3">
                  <strong>Total:</strong>
                  <strong>$8,450.00</strong>
                </div>

                <div class="mb-4">
                  <h6>Payment Information</h6>
                  <div class="card bg-light p-3">
                    <div class="d-flex justify-content-between">
                      <span>Method:</span>
                      <span>Credit Card (**** 1234)</span>
                    </div>
                    <div class="d-flex justify-content-between">
                      <span>Date:</span>
                      <span>Nov 1, 2023</span>
                    </div>
                    <div class="d-flex justify-content-between">
                      <span>Status:</span>
                      <span class="badge bg-success">Paid</span>
                    </div>
                  </div>
                </div>

                <div class="d-grid gap-2">
                  <button class="btn btn-outline-primary">
                    <i class="bi bi-download me-2"></i> Download Invoice
                  </button>
                  <button class="btn btn-outline-secondary">
                    <i class="bi bi-printer me-2"></i> Print Invoice
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light py-4 mt-5">
      <div class="container-fluid">
        <div class="row">
          <div class="col-md-6">
            <p class="mb-0">&copy; 2023 ProcurePro. All rights reserved.</p>
          </div>
          <div class="col-md-6 text-md-end">
            <a href="#" class="text-muted me-3">Help & Support</a>
            <a href="#" class="text-muted me-3">Privacy Policy</a>
            <a href="#" class="text-muted">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Company JS -->
    <script src="../assets/js/company.js"></script>
  </body>
</html>
