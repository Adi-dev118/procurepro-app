<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cart — ProcurePro</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../assets/css/style.css" />
    <link rel="stylesheet" href="../assets/css/company-style.css" />
    <style>
      :root {
        --col-bg: #eef2f9;
        --col-surface: #f7f9fd;
        --col-surface-2: #edf1f8;
        --col-border: #cdd8ee;
        --col-border-strong: #b3c3e0;
        --col-text-primary: #0f1e3d;
        --col-text-secondary: #3d5070;
        --col-text-muted: #7a90b8;
        --col-accent: #1d6bf3;
        --col-accent-light: #dce8fd;
        --col-accent-hover: #1558d6;
        --col-success: #0f9960;
        --col-success-light: #d6f0e6;
        --col-warning: #b45309;
        --col-warning-light: #fef3d9;
        --col-danger: #dc2626;
        --col-danger-light: #fde8e8;
        --col-purple: #5b21b6;
        --col-purple-light: #ede9fe;
        --nav-w: 240px;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --radius-xl: 20px;
        --shadow-sm: 0 1px 4px rgba(29, 107, 243, 0.07);
        --shadow-md: 0 4px 16px rgba(29, 107, 243, 0.1);
        --shadow-lg: 0 8px 28px rgba(29, 107, 243, 0.15);
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--col-bg);
        color: var(--col-text-primary);
        font-size: 14px;
        line-height: 1.6;
      }
      .shell {
        display: flex;
        min-height: 100vh;
      }

      /* ── Sidebar ── */
      .sidebar {
        width: var(--nav-w);
        background: #0f1e3d;
        border-right: 1px solid #1a3060;
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        transition: transform 0.25s ease;
      }
      .sidebar-logo {
        padding: 24px 20px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .logo-mark {
        width: 34px;
        height: 34px;
        background: var(--col-accent);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        font-weight: 700;
        flex-shrink: 0;
      }
      .logo-name {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        letter-spacing: -0.3px;
      }
      .logo-badge {
        font-size: 10px;
        color: var(--col-accent);
        background: var(--col-accent-light);
        padding: 1px 6px;
        border-radius: 20px;
        font-weight: 600;
        margin-top: 1px;
      }
      .sidebar-section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        padding: 18px 20px 6px;
      }
      .sidebar-nav {
        overflow-y: auto;
        scroll-behavior: smooth;
        flex: 1;
      }
      .sidebar-nav::-webkit-scrollbar {
        width: 0;
      }
      .sidebar-nav:hover::-webkit-scrollbar {
        width: 6px;
      }
      .sidebar-nav:hover::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.25);
        border-radius: 10px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: var(--radius-sm);
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        font-weight: 500;
        font-size: 13.5px;
        transition: all 0.15s;
        margin-bottom: 2px;
      }
      .nav-item i {
        font-size: 15px;
        width: 18px;
        text-align: center;
        flex-shrink: 0;
      }
      .nav-item:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
      }
      .nav-item.active {
        background: rgba(29, 107, 243, 0.25);
        color: #fff;
        font-weight: 600;
      }
      .nav-badge {
        margin-left: auto;
        background: var(--col-danger);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 20px;
        min-width: 18px;
        text-align: center;
      }
      .nav-badge.warning {
        background: var(--col-warning-light);
        color: var(--col-warning);
      }

      /* ── User Popup ── */
      .sidebar-footer {
        position: relative;
      }
      .user-card {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 16px;
        cursor: pointer;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        transition: background 0.15s;
      }
      .user-card:hover {
        background: rgba(255, 255, 255, 0.05);
      }
      .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--col-accent);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
      }
      .user-name {
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        line-height: 1.2;
      }
      .user-role {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.4);
      }
      .user-chevron {
        margin-left: auto;
        color: rgba(255, 255, 255, 0.35);
        font-size: 13px;
        transition: transform 0.2s ease;
      }
      .user-card.active .user-chevron {
        transform: rotate(180deg);
      }
      .user-popup {
        position: fixed;
        bottom: 80px;
        left: 14px;
        width: calc(var(--nav-w) - 28px);
        background: #0d1f42;
        border: 1px solid #2a4a80;
        border-radius: var(--radius-md);
        box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.55);
        overflow: hidden;
        transform: translateY(10px);
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.2s ease,
          transform 0.2s ease;
        z-index: 9999;
      }
      .user-popup.open {
        opacity: 1;
        transform: translateY(0);
        pointer-events: all;
      }
      .user-popup-header {
        padding: 10px 14px 8px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.7px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
      }
      .user-popup-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        color: rgba(255, 255, 255, 0.75);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition:
          background 0.15s,
          color 0.15s;
        cursor: pointer;
      }
      .user-popup-item i {
        font-size: 14px;
        width: 16px;
        text-align: center;
        color: rgba(255, 255, 255, 0.45);
        flex-shrink: 0;
        margin-left: 0;
      }
      .user-popup-item:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
      }
      .user-popup-item:hover i {
        color: #5ba4fb;
      }
      .user-popup-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
        margin: 4px 0;
      }
      .user-popup-item.danger {
        color: #f87171;
      }
      .user-popup-item.danger i {
        color: #f87171;
      }
      .user-popup-item.danger:hover {
        background: rgba(220, 38, 38, 0.12);
        color: #fca5a5;
      }
      .user-popup-item.danger:hover i {
        color: #fca5a5;
      }

      /* ── Main layout ── */
      .main {
        margin-left: var(--nav-w);
        flex: 1;
        min-height: 100vh;
      }
      .topbar {
        background: #f7f9fd;
        border-bottom: 1px solid #cdd8ee;
        height: 60px;
        display: flex;
        align-items: center;
        padding: 0 28px;
        gap: 16px;
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: 0 1px 4px rgba(29, 107, 243, 0.07);
      }
      .topbar-title {
        font-size: 15px;
        font-weight: 600;
        flex: 1;
      }
      .topbar-search {
        display: flex;
        align-items: center;
        background: var(--col-bg);
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        padding: 7px 12px;
        gap: 8px;
        width: 280px;
        transition: all 0.15s;
      }
      .topbar-search:focus-within {
        border-color: var(--col-accent);
        background: #fff;
        box-shadow: 0 0 0 3px rgba(29, 107, 243, 0.1);
      }
      .topbar-search i {
        color: var(--col-text-muted);
        font-size: 13px;
      }
      .topbar-search input {
        border: none;
        background: none;
        outline: none;
        font-size: 13px;
        font-family: inherit;
        color: var(--col-text-primary);
        width: 100%;
      }
      .topbar-search input::placeholder {
        color: var(--col-text-muted);
      }
      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .icon-btn {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--col-border);
        background: var(--col-surface);
        color: var(--col-text-secondary);
        cursor: pointer;
        transition: all 0.15s;
        position: relative;
      }
      .icon-btn:hover {
        background: var(--col-bg);
        color: var(--col-text-primary);
      }
      .icon-btn .dot {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--col-danger);
        border: 1.5px solid var(--col-surface);
      }
      .btn-primary-action {
        background: var(--col-accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 8px 16px;
        font-family: inherit;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: all 0.15s;
        white-space: nowrap;
      }
      .btn-primary-action:hover {
        background: var(--col-accent-hover);
      }
      .btn-ghost {
        background: none;
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        padding: 7px 14px;
        font-family: inherit;
        font-size: 12.5px;
        font-weight: 500;
        color: var(--col-text-secondary);
        cursor: pointer;
        transition: all 0.15s;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .btn-ghost:hover {
        background: var(--col-bg);
        color: var(--col-text-primary);
      }

      /* ── Page ── */
      .page-content {
        padding: 28px;
      }
      .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 24px;
      }
      .page-title {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -0.4px;
        line-height: 1.2;
      }
      .page-subtitle {
        font-size: 13px;
        color: var(--col-text-muted);
        margin-top: 3px;
      }

      /* ── Cart Layout ── */
      .cart-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 24px;
        align-items: start;
      }

      /* ── Cart Items Panel ── */
      .cart-panel {
        background: var(--col-surface);
        border: 1px solid var(--col-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
      }
      .cart-panel-header {
        padding: 18px 22px;
        border-bottom: 1px solid var(--col-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .cart-panel-title {
        font-size: 15px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .cart-count-badge {
        background: var(--col-accent-light);
        color: var(--col-accent);
        font-size: 11px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
      }
      .cart-clear-btn {
        font-size: 12px;
        color: var(--col-danger);
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 4px 8px;
        border-radius: var(--radius-sm);
        transition: background 0.15s;
      }
      .cart-clear-btn:hover {
        background: var(--col-danger-light);
      }

      /* ── Cart Card ── */
      .cart-card {
        display: grid;
        grid-template-columns: 90px 1fr auto;
        gap: 16px;
        padding: 20px 22px;
        border-bottom: 1px solid var(--col-border);
        transition: background 0.15s;
        align-items: center;
      }
      .cart-card:last-child {
        border-bottom: none;
      }
      .cart-card:hover {
        background: #f0f4fb;
      }

      /* product image thumb */
      .cart-img {
        width: 90px;
        height: 80px;
        border-radius: var(--radius-md);
        background: linear-gradient(145deg, #dce8fd 0%, #eef2f9 100%);
        border: 1px solid var(--col-border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
      }
      .cart-img i {
        font-size: 30px;
        color: #b3c3e0;
      }
      .cart-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* product info */
      .cart-info {
        min-width: 0;
      }
      .cart-cat {
        font-size: 10.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--col-accent);
        margin-bottom: 4px;
      }
      .cart-name {
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .cart-supplier {
        font-size: 12px;
        color: var(--col-text-muted);
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 10px;
      }
      .cart-supplier i {
        font-size: 11px;
      }
      .cart-price-row {
        display: flex;
        align-items: baseline;
        gap: 6px;
      }
      .cart-unit-price {
        font-size: 16px;
        font-weight: 700;
        letter-spacing: -0.4px;
      }
      .cart-per-unit {
        font-size: 11px;
        color: var(--col-text-muted);
      }
      .cart-subtotal-label {
        font-size: 11.5px;
        color: var(--col-text-muted);
        margin-top: 2px;
      }
      .cart-subtotal-label span {
        font-weight: 600;
        color: var(--col-text-secondary);
      }

      /* right controls */
      .cart-controls {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 12px;
        flex-shrink: 0;
      }
      .qty-control {
        display: flex;
        align-items: center;
        gap: 0;
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        overflow: hidden;
        background: #fff;
      }
      .qty-btn {
        width: 32px;
        height: 32px;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--col-text-secondary);
        font-size: 14px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          background 0.15s,
          color 0.15s;
        font-family: inherit;
      }
      .qty-btn:hover {
        background: var(--col-accent-light);
        color: var(--col-accent);
      }
      .qty-btn:active {
        background: var(--col-accent);
        color: #fff;
      }
      .qty-input {
        width: 44px;
        height: 32px;
        border: none;
        border-left: 1px solid var(--col-border);
        border-right: 1px solid var(--col-border);
        text-align: center;
        font-family: 'DM Mono', monospace;
        font-size: 13px;
        font-weight: 500;
        color: var(--col-text-primary);
        background: #fff;
        outline: none;
        -moz-appearance: textfield;
      }
      .qty-input::-webkit-outer-spin-button,
      .qty-input::-webkit-inner-spin-button {
        -webkit-appearance: none;
      }
      .delete-btn {
        width: 32px;
        height: 32px;
        background: none;
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        cursor: pointer;
        color: var(--col-text-muted);
        font-size: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
      }
      .delete-btn:hover {
        background: var(--col-danger-light);
        border-color: var(--col-danger);
        color: var(--col-danger);
      }
      .cart-line-total {
        font-size: 15px;
        font-weight: 700;
        color: var(--col-text-primary);
        letter-spacing: -0.3px;
        white-space: nowrap;
      }

      /* ── Empty State ── */
      .cart-empty {
        padding: 64px 32px;
        text-align: center;
        display: none;
      }
      .cart-empty i {
        font-size: 48px;
        color: var(--col-border-strong);
        margin-bottom: 16px;
      }
      .cart-empty-title {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 6px;
      }
      .cart-empty-sub {
        font-size: 13px;
        color: var(--col-text-muted);
        margin-bottom: 20px;
      }
      .cart-empty a {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--col-accent);
        color: #fff;
        text-decoration: none;
        padding: 9px 20px;
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 600;
        transition: background 0.15s;
      }
      .cart-empty a:hover {
        background: var(--col-accent-hover);
      }

      /* ── Order Summary ── */
      .summary-panel {
        background: var(--col-surface);
        border: 1px solid var(--col-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        position: sticky;
        top: 80px;
      }
      .summary-header {
        padding: 18px 22px;
        border-bottom: 1px solid var(--col-border);
        font-size: 15px;
        font-weight: 700;
      }
      .summary-body {
        padding: 20px 22px;
      }
      .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-size: 13.5px;
      }
      .summary-row .label {
        color: var(--col-text-secondary);
      }
      .summary-row .value {
        font-weight: 600;
      }
      .summary-row.discount .value {
        color: var(--col-success);
      }
      .summary-row.tax .value {
        color: var(--col-text-muted);
      }
      .summary-divider {
        height: 1px;
        background: var(--col-border);
        margin: 16px 0;
      }
      .summary-total {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 20px;
      }
      .summary-total .total-label {
        font-size: 15px;
        font-weight: 700;
      }
      .summary-total .total-value {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -0.6px;
      }
      .btn-checkout {
        width: 100%;
        padding: 12px;
        background: var(--col-accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.15s;
        letter-spacing: 0.2px;
      }
      .btn-checkout:hover {
        background: var(--col-accent-hover);
        box-shadow: 0 4px 12px rgba(29, 107, 243, 0.3);
      }
      .btn-save-rfq {
        width: 100%;
        padding: 10px;
        background: none;
        color: var(--col-accent);
        border: 1.5px solid var(--col-accent);
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        transition: all 0.15s;
        margin-top: 10px;
      }
      .btn-save-rfq:hover {
        background: var(--col-accent-light);
      }
      .summary-perks {
        margin-top: 18px;
      }
      .perk-item {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 12px;
        color: var(--col-text-muted);
        margin-bottom: 9px;
      }
      .perk-item i {
        font-size: 14px;
        color: var(--col-success);
        flex-shrink: 0;
      }

      /* coupon input */
      .coupon-row {
        display: flex;
        gap: 8px;
        margin-bottom: 18px;
      }
      .coupon-input {
        flex: 1;
        padding: 8px 12px;
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 13px;
        color: var(--col-text-primary);
        background: var(--col-bg);
        outline: none;
        transition: border-color 0.15s;
      }
      .coupon-input:focus {
        border-color: var(--col-accent);
        background: #fff;
      }
      .coupon-input::placeholder {
        color: var(--col-text-muted);
      }
      .btn-apply {
        padding: 8px 14px;
        background: var(--col-surface-2);
        border: 1px solid var(--col-border);
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--col-text-secondary);
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
      }
      .btn-apply:hover {
        border-color: var(--col-accent);
        color: var(--col-accent);
        background: var(--col-accent-light);
      }

      /* ── Responsive ── */
      @media (max-width: 1100px) {
        .cart-layout {
          grid-template-columns: 1fr;
        }
        .summary-panel {
          position: static;
        }
      }
      @media (max-width: 768px) {
        .sidebar {
          transform: translateX(-100%);
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .main {
          margin-left: 0;
        }
        .page-content {
          padding: 16px;
        }
        .cart-card {
          grid-template-columns: 70px 1fr;
        }
        .cart-controls {
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: flex-start;
          grid-column: 1 / -1;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
          <div class="logo-mark">P</div>
          <div>
            <div class="logo-name">ProcurePro</div>
            <div class="logo-badge">BUYER</div>
          </div>
        </div>
        <nav class="sidebar-nav">
          <div class="sidebar-section-label">Main</div>
          <a href="/dashboard" class="nav-item"
            ><i class="bi bi-grid-1x2"></i><span>Dashboard</span></a
          >
          <a href="/marketplace" class="nav-item"
            ><i class="bi bi-shop"></i><span>Marketplace</span></a
          >
          <a href="/rfq" class="nav-item"
            ><i class="bi bi-megaphone"></i><span>RFQ Center</span
            ><span class="nav-badge warning">5</span></a
          >
          <div class="sidebar-section-label">Procurement</div>
          <a href="/orders" class="nav-item"
            ><i class="bi bi-cart-check"></i><span>Orders</span><span class="nav-badge">3</span></a
          >
          <a href="/contracts" class="nav-item"
            ><i class="bi bi-file-earmark-text"></i><span>Contracts</span></a
          >
          <a href="/invoices" class="nav-item"
            ><i class="bi bi-receipt"></i><span>Invoices</span></a
          >
          <a href="/suppliers" class="nav-item"
            ><i class="bi bi-people"></i><span>Suppliers</span></a
          >
          <div class="sidebar-section-label">Account</div>
          <a href="/analytics" class="nav-item"
            ><i class="bi bi-bar-chart-line"></i><span>Analytics</span></a
          >
          <a href="/profile" class="nav-item"
            ><i class="bi bi-person-circle"></i><span>Profile & Team</span></a
          >
          <a href="/settings" class="nav-item"><i class="bi bi-gear"></i><span>Settings</span></a>
          <a href="/cart" class="nav-item active"><i class="bi bi-cart3"></i><span>Cart</span></a>
        </nav>
        <div class="sidebar-footer">
          <div class="user-popup" id="userPopup">
            <div class="user-popup-header">My Account</div>
            <a href="/profile" class="user-popup-item"
              ><i class="bi bi-person-circle"></i> Profile</a
            >
            <a href="/cart" class="user-popup-item"><i class="bi bi-cart3"></i> Cart</a>
            <a href="/settings" class="user-popup-item"><i class="bi bi-gear"></i> Settings</a>
            <div class="user-popup-divider"></div>
            <a href="/company/login" class="user-popup-item danger"
              ><i class="bi bi-box-arrow-left"></i> Sign Out</a
            >
          </div>
          <div class="user-card" id="userCard">
            <div class="user-avatar"><span id="userInitials"></span></div>
            <div>
              <div class="user-name" id="userName"></div>
              <div class="user-role">Buyer Account</div>
            </div>
            <i class="bi bi-chevron-up user-chevron"></i>
          </div>
        </div>
      </aside>

      <div class="main">
        <!-- Topbar -->
        <header class="topbar">
          <button class="icon-btn d-lg-none" id="menuToggle" style="border: none">
            <i class="bi bi-list" style="font-size: 18px"></i>
          </button>
          <span class="topbar-title d-none d-md-block">Cart</span>
          <div class="topbar-search ms-auto ms-md-0">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search products, suppliers, categories…" />
          </div>
          <div class="topbar-actions">
            <div class="icon-btn">
              <i class="bi bi-bell" style="font-size: 15px"></i><span class="dot"></span>
            </div>
            <a href="/marketplace" class="btn-primary-action">
              <i class="bi bi-shop"></i> Continue Shopping
            </a>
          </div>
        </header>

        <div class="page-content">
          <div class="page-header">
            <div>
              <div class="page-title">My Cart</div>
              <div class="page-subtitle" id="cartSubtitle">Loading your items…</div>
            </div>
          </div>

          <div class="cart-layout">
            <!-- Left: cart items -->
            <div>
              <div class="cart-panel">
                <div class="cart-panel-header">
                  <div class="cart-panel-title">
                    <i class="bi bi-cart3" style="color: var(--col-accent)"></i>
                    Cart Items
                    <span class="cart-count-badge" id="itemCountBadge">0</span>
                  </div>
                  <button class="cart-clear-btn" id="clearCartBtn">
                    <i class="bi bi-trash3"></i> Clear all
                  </button>
                </div>

                <!-- Items injected here -->
                <div id="cartItemsContainer">

                </div>

                <!-- Empty state -->
                <div class="cart-empty" id="emptyState">
                  <i class="bi bi-cart-x"></i>
                  <div class="cart-empty-title">Your cart is empty</div>
                  <div class="cart-empty-sub">
                    Browse the marketplace and add items to get started.
                  </div>
                  <a href="/marketplace"><i class="bi bi-shop"></i> Browse Marketplace</a>
                </div>
              </div>
            </div>

            <!-- Right: summary -->
            <div>
              <div class="summary-panel">
                <div class="summary-header">Order Summary</div>
                <div class="summary-body">
                  <!-- Coupon -->
                  <div class="coupon-row">
                    <input
                      class="coupon-input"
                      type="text"
                      placeholder="Promo / coupon code"
                      id="couponInput"
                    />
                    <button class="btn-apply" id="applyBtn">Apply</button>
                  </div>

                  <div class="summary-row">
                    <span class="label">Subtotal (<span id="summaryQty">0</span> items)</span>
                    <span class="value" id="summarySubtotal">$0.00</span>
                  </div>
                  <div class="summary-row discount" id="discountRow" style="display: none">
                    <span class="label">Promo discount</span>
                    <span class="value" id="discountValue">-$0.00</span>
                  </div>
                  <div class="summary-row tax">
                    <span class="label">Estimated tax (8%)</span>
                    <span class="value" id="summaryTax">$0.00</span>
                  </div>
                  <div class="summary-row">
                    <span class="label">Shipping</span>
                    <span class="value" style="color: var(--col-success)">Free</span>
                  </div>
                  <div class="summary-divider"></div>
                  <div class="summary-total">
                    <span class="total-label">Total</span>
                    <span class="total-value" id="summaryTotal">$0.00</span>
                  </div>

                  <button class="btn-checkout" id="checkoutBtn">
                    <i class="bi bi-lock"></i> Proceed to Checkout
                  </button>
                  <button class="btn-save-rfq">
                    <i class="bi bi-megaphone"></i> Convert to RFQ
                  </button>

                  <div class="summary-perks">
                    <div class="perk-item">
                      <i class="bi bi-shield-check"></i> Secure B2B checkout
                    </div>
                    <div class="perk-item">
                      <i class="bi bi-truck"></i> Free shipping on all orders
                    </div>
                    <div class="perk-item">
                      <i class="bi bi-arrow-counterclockwise"></i> 30-day return policy
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="../assets/js/company/cart/cart.main.js"></script>
    
    <script>
      // ── Sidebar toggle ──
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      if (menuToggle) {
        menuToggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
          if (!sidebar.contains(e.target) && !menuToggle.contains(e.target))
            sidebar.classList.remove('open');
        });
      }

      // ── User popup ──
      const userCard = document.getElementById('userCard');
      const userPopup = document.getElementById('userPopup');
      if (userCard && userPopup) {
        userCard.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = userPopup.classList.toggle('open');
          userCard.classList.toggle('active', isOpen);
        });
        document.addEventListener('click', (e) => {
          if (!userCard.contains(e.target) && !userPopup.contains(e.target)) {
            userPopup.classList.remove('open');
            userCard.classList.remove('active');
          }
        });
      }
    </script>
  </body>
</html>
