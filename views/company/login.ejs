<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ProcurePro — Login</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/company-style.css" />
  </head>
  <body>
    <nav class="navbar">
      <a href="#" class="navbar-brand">
        <div class="brand-icon">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"
            />
          </svg>
        </div>
        ProcurePro
      </a>
    </nav>

    <div class="page">
      <div class="container">
        <div class="banner">
          <div class="banner-icon">🏢</div>
          <div>
            <h2>Welcome to ProcurePro</h2>
            <p>Track procurement activities, manage RFQs, and discover trusted suppliers</p>
          </div>
        </div>

        <div class="card">
          <div class="tabs">
            <div class="tab active" id="tLogin" onclick="switchTab('login')">Sign In</div>
            <div class="tab" id="tSignup" onclick="switchTab('signup')">Create Account</div>
          </div>

          <!-- ── LOGIN ── -->
          <div class="panel active" id="pLogin">
            <div class="heading">
              <h1>Sign in to your account</h1>
              <p>Enter your credentials to access your dashboard</p>
            </div>

            <div class="form-group">
              <label>Email Address <span class="req">*</span></label>
              <div class="input-wrap">
                <svg
                  class="ico"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
                <input type="email" id="lEmail" placeholder="you@company.com" />
              </div>
              <div class="err" id="lEmailErr">Please enter a valid email address</div>
            </div>

            <div class="form-group">
              <label>Password <span class="req">*</span></label>
              <div class="input-wrap">
                <svg
                  class="ico"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  />
                </svg>
                <input type="password" id="lPass" placeholder="Enter your password" />
                <button
                  type="button"
                  class="eye-btn"
                  onclick="togglePass(this)"
                  tabindex="-1"
                  aria-label="Toggle password"
                >
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                    />
                  </svg>
                </button>
              </div>
              <div class="err" id="lPassErr">Password is required</div>
            </div>

            <div class="forgot"><a href="#">Forgot password?</a></div>

            <button class="btn-primary" id="loginBtn">
              <svg
                width="15"
                height="15"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"
                />
              </svg>
              Sign In
            </button>

            <div class="divider">or</div>
            <button class="btn-outline">
              <img src="https://www.google.com/favicon.ico" alt="Google" />
              Continue with Google
            </button>

            <div class="switch-text">
              Don't have an account? <a onclick="switchTab('signup')">Create one</a>
            </div>
          </div>

          <!-- ── SIGNUP ── -->
          <div class="panel" id="pSignup">
            <div class="heading">
              <h1>Create your account</h1>
              <p>Create an account to start purchasing products.</p>
            </div>

            <!-- Supplier notice -->
            <div class="notice">
              <span class="notice-icon">🏪</span>
              <div class="notice-text">
                <strong>Want to become a supplier?</strong>
                Apply after logging in — supplier applications are reviewed and approved by our
                admin team.
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>First Name <span class="req">*</span></label>
                <div class="input-wrap">
                  <svg
                    class="ico"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    />
                  </svg>
                  <input type="text" id="sFirst" placeholder="John" />
                </div>
                <div class="err" id="sFirstErr">Required</div>
              </div>
              <div class="form-group">
                <label>Last Name <span class="req">*</span></label>
                <div class="input-wrap">
                  <svg
                    class="ico"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    />
                  </svg>
                  <input type="text" id="sLast" placeholder="Doe" />
                </div>
                <div class="err" id="sLastErr">Required</div>
              </div>
            </div>

            <div class="form-group">
              <label>Email Address <span class="req">*</span></label>
              <div class="input-wrap">
                <svg
                  class="ico"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
                <input type="email" id="sEmail" placeholder="you@company.com" />
              </div>
              <div class="err" id="sEmailErr">Please enter a valid email address</div>
            </div>

            <div class="form-group">
              <label>Password <span class="req">*</span></label>
              <div class="input-wrap">
                <svg
                  class="ico"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  />
                </svg>
                <input
                  type="password"
                  id="sPass"
                  placeholder="Min. 8 characters"
                  oninput="checkStrength(this.value)"
                />
                <button
                  type="button"
                  class="eye-btn"
                  onclick="togglePass(this)"
                  tabindex="-1"
                  aria-label="Toggle password"
                >
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                    />
                  </svg>
                </button>
              </div>
              <div class="strength" id="sBar"><div class="strength-fill" id="sFill"></div></div>
              <div class="err" id="sPassErr">Password must be at least 8 characters</div>
            </div>

            <div class="form-group">
              <label>Confirm Password <span class="req">*</span></label>
              <div class="input-wrap">
                <svg
                  class="ico"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  />
                </svg>
                <input type="password" id="sConfirm" placeholder="Repeat your password" />
                <button
                  type="button"
                  class="eye-btn"
                  onclick="togglePass(this)"
                  tabindex="-1"
                  aria-label="Toggle password"
                >
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                    />
                  </svg>
                </button>
              </div>
              <div class="err" id="sConfirmErr">Passwords do not match</div>
            </div>

            <button class="btn-primary" style="margin-top: 4px" id="signupBtn">
              <svg
                width="15"
                height="15"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"
                />
              </svg>
              Create Account
            </button>

            <p class="terms">
              By creating an account you agree to our
              <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
            </p>

            <div class="switch-text">
              Already have an account? <a onclick="switchTab('login')">Sign in</a>
            </div>
          </div>
        </div>
        <!-- /card -->
      </div>
    </div>

    <div class="toast" id="toast">
      <span class="toast-tick">✓</span>
      <span id="toastMsg"></span>
    </div>

    <script src="/assets/js/company.js"></script>
  </body>
</html>
