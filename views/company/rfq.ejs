<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RFQ Center - ProcurePro</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
    />

    <!-- Shared CSS -->
    <link rel="stylesheet" href="../assets/css/style.css" />

    <!-- Company CSS -->
    <link rel="stylesheet" href="../assets/css/company-style.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../assets/img/favicon.ico" />
  </head>
  <body class="company-dashboard">
    <!-- Header (Same as dashboard) -->
    <header class="company-header">
      <div class="container-fluid d-flex justify-content-between align-items-center">
        <div class="company-logo">
          <i class="bi bi-building"></i>
          <span>ProcurePro</span>
        </div>

        <button class="mobile-menu-btn d-lg-none">
          <i class="bi bi-list"></i>
        </button>

        <nav class="company-nav d-none d-lg-flex">
          <a href="/dashboard" class="company-nav-link">
            <i class="bi bi-speedometer2 me-1"></i> Dashboard
          </a>
          <a href="/marketplace" class="company-nav-link">
            <i class="bi bi-shop me-1"></i> Marketplace
          </a>
          <a href="/rfq" class="company-nav-link active">
            <i class="bi bi-megaphone me-1"></i> RFQ Center
          </a>
          <a href="/orders" class="company-nav-link">
            <i class="bi bi-cart-check me-1"></i> Orders
          </a>
          <a href="/profile" class="company-nav-link">
            <i class="bi bi-person-circle me-1"></i> Profile
          </a>
        </nav>

        <div class="company-actions">
          <div class="search-box-company d-none d-md-block">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search RFQs..." />
          </div>

          <button class="notification-btn">
            <i class="bi bi-bell"></i>
            <span class="notification-badge">3</span>
          </button>

          <div class="company-profile">
            <div class="company-avatar">
              <%= name.name.split(' ').map(word => word[0]).join('').toUpperCase() %>
            </div>
            <div class="d-none d-md-block">
              <div class="company-name"><%=name.name%></div>
              <div class="text-muted small">Buyer Account</div>
            </div>
            <i class="bi bi-chevron-down"></i>
          </div>
        </div>
      </div>

      <div class="company-nav-mobile d-lg-none">
        <a href="/dashboard" class="company-nav-link">
          <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
        <a href="/marketplace" class="company-nav-link">
          <i class="bi bi-shop me-2"></i> Marketplace
        </a>
        <a href="/rfq" class="company-nav-link active">
          <i class="bi bi-megaphone me-2"></i> RFQ Center
        </a>
        <a href="/orders" class="company-nav-link">
          <i class="bi bi-cart-check me-2"></i> Orders
        </a>
        <a href="/profile" class="company-nav-link">
          <i class="bi bi-person-circle me-2"></i> Profile
        </a>
      </div>

      <div class="mobile-overlay"></div>
    </header>

    <!-- Main Content -->
    <main class="company-main">
      <div class="container-fluid py-4">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <h1 class="h2 mb-1">RFQ Center</h1>
            <p class="text-muted mb-0">Manage your Request for Quotations and Tenders</p>
          </div>
          <div>
            <button class="btn btn-primary create-rfq-btn">
              <i class="bi bi-plus-circle me-2"></i> Create New RFQ
            </button>
          </div>
        </div>

        <!-- RFQ Tabs -->
        <ul class="nav nav-tabs mb-4" id="rfqTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button
              class="nav-link active"
              id="active-tab"
              data-bs-toggle="tab"
              data-bs-target="#active"
              type="button"
            >
              Active RFQs (<%=activeRFQs.length%>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button
              class="nav-link"
              id="pending-tab"
              data-bs-toggle="tab"
              data-bs-target="#pending"
              type="button"
            >
              Pending Review (<%=pendingRFQs.length%>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button
              class="nav-link"
              id="closed-tab"
              data-bs-toggle="tab"
              data-bs-target="#closed"
              type="button"
            >
              Closed/Awarded (<%=closedRFQs.length%>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button
              class="nav-link"
              id="draft-tab"
              data-bs-toggle="tab"
              data-bs-target="#draft"
              type="button"
            >
              Drafts (1)
            </button>
          </li>
        </ul>

        <!-- RFQ Tab Content -->

        <div class="tab-content" id="rfqTabsContent">
          <%currentRFQs.forEach(rfq => {%>
          <!-- Active RFQs -->
          <div class="tab-pane fade show active" id="active" role="tabpanel">
            <!-- RFQ Card 1 -->
            <%if(rfq.status === 'active'){%>
            <div class="rfq-card">
              <div class="rfq-header">
                <div>
                  <h4 class="mb-1"><%=rfq.title%> - <%=rfq.quantity%> Units</h4>
                  <div class="rfq-meta">
                    <span>#RFQ-00<%=rfq.id%></span>
                    <span
                      ><i class="bi bi-calendar"></i> Deadline:
                      <%= new Date(rfq.deadline).toLocaleDateString('en-US', {
                                    month: 'short',
                                    day: 'numeric',
                                    year: 'numeric'
                        }) %></span
                    >
                    <span
                      ><i class="bi bi-people"></i>
                      <%=rfq.suppliers_invited%>
                      Suppliers Invited</span
                    >
                    <span
                      ><i class="bi bi-file-text"></i>
                      <%=rfq.bids_received%>
                      Bids Received</span
                    >
                  </div>
                </div>
                <div>
                  <span class="rfq-status open">Open for Bids</span>
                </div>
              </div>

              <div class="rfq-details">
                <p class="rfq-description"><%=rfq.description%></p>

                <div class="rfq-specs">
                  <h6>Specifications:</h6>
                  <ul class="mb-0">
                    <%rfq.specifications.forEach(spec=> {%>
                    <li>
                      <%=spec.spec_name%>:
                      <%=spec.spec_value%>
                    </li>
                    <%})%>
                  </ul>
                </div>

                <div class="rfq-bids">
                  <h6 class="mb-3">Received Bids:</h6>

                  <!-- Bid 1 -->
                  <%rfq.quotes.forEach(quote=> {%>
                  <div class="bid-card">
                    <div class="bid-header">
                      <div class="bid-supplier">
                        <div class="supplier-avatar">
                          <%= quote.company.split(' ').map(word => word[0]).join('').toUpperCase()
                          %>
                        </div>
                        <div>
                          <h6 class="mb-0"><%=quote.company%></h6>
                          <p class="text-muted small mb-0">
                            <%=quote.rating%> ★ (<%=quote.review_count%> reviews)
                          </p>
                        </div>
                      </div>
                      <div class="bid-price">$<%=quote.price%></div>
                    </div>
                    <div class="bid-details">
                      <p class="mb-2">
                        Delivery: <%=quote.delivery_days%> days | Warranty: <%=quote.warranty%>
                        years | Payment: <%=quote.payment_terms%>
                      </p>
                      <p class="mb-0">
                        <strong>Notes:</strong>
                        <%=quote.message%>
                      </p>
                    </div>
                    <div class="bid-actions">
                      <button class="btn btn-success btn-sm accept-bid-btn" data-bid-id="bid1">
                        <i class="bi bi-check-circle me-1"></i> Accept Bid
                      </button>
                      <button class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-chat-left-text me-1"></i> Message
                      </button>
                      <button class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye me-1"></i> View Details
                      </button>
                    </div>
                  </div>
                  <%})%>
                </div>
              </div>
            </div>
            <%}%>
          </div>

          <!-- Pending Review -->
          <%if(rfq.status=== 'expired'){%>
          <div class="tab-pane fade" id="pending" role="tabpanel">
            <!-- RFQ Card for Pending -->
            <div class="rfq-card">
              <div class="rfq-header">
                <div>
                  <h4 class="mb-1"><%=rfq.title%></h4>
                  <div class="rfq-meta">
                    <span><i class="bi bi-hash"></i> #RFQ-00<%=rfq.id%></span>
                    <span><i class="bi bi-calendar"></i> Posted: Nov 6, 2023</span>
                    <span
                      ><i class="bi bi-people"></i>
                      <%=rfq.suppliers_invited%>
                      Suppliers Invited</span
                    >
                    <span><i class="bi bi-clock"></i> 2 Days Remaining</span>
                  </div>
                </div>
                <div>
                  <span class="rfq-status open">Awaiting Bids</span>
                </div>
              </div>

              <div class="rfq-details">
                <p class="rfq-description"><%=rfq.description%></p>

                <div class="text-center py-4">
                  <i class="bi bi-clock display-4 text-muted mb-3"></i>
                  <h5>Awaiting Supplier Bids</h5>
                  <p class="text-muted">No bids received yet. Check back after the deadline.</p>
                </div>
              </div>
            </div>
          </div>
          <%}%>

          <!-- Closed/Awarded -->
          <%if(rfq.status === 'closed') {%>
          <div class="tab-pane fade" id="closed" role="tabpanel">
            <!-- RFQ Card for Closed -->
            <div class="rfq-card">
              <div class="rfq-header">
                <div>
                  <h4 class="mb-1"><%=rfq.title%></h4>
                  <div class="rfq-meta">
                    <span><i class="bi bi-hash"></i> #RFQ-<%=rfq.id%></span>
                    <span
                      ><i class="bi bi-calendar"></i> Closed:
                      <%= new Date(rfq.deadline).toLocaleDateString('en-US', {
                                    month: 'short',
                                    day: 'numeric',
                                    year: 'numeric'
                        }) %></span
                    >
                    <span
                      ><i class="bi bi-people"></i>
                      <%=rfq.suppliers_invited%>
                      Suppliers Invited</span
                    >
                    <span
                      ><i class="bi bi-file-text"></i>
                      <%=rfq.bids_received%>
                      Bids Received</span
                    >
                  </div>
                </div>
                <div>
                  <span class="rfq-status awarded">Awarded</span>
                </div>
              </div>

              <div class="rfq-details">
                <p class="rfq-description"><%=rfq.description%></p>

                <div class="alert alert-success">
                  <div class="d-flex">
                    <i class="bi bi-check-circle-fill me-3 fs-4"></i>
                    <div>
                      <%rfq.quotes.forEach(quote=> {%>
                      <%if(quote.status === 'won'){%>
                      <h6 class="alert-heading">Awarded to: <%=quote.company%></h6>
                      <p class="mb-1">Winning Bid: $<%=quote.price%> | Delivery: <%=quote.delivery_days%> days</p>
                      <p class="mb-0">Order #ORD-<%=quote.order_id%> created from this RFQ</p>
                      <%}%>
                      <%})%>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <%}%>

          <!-- Drafts -->
          <div class="tab-pane fade" id="draft" role="tabpanel">
            <div class="rfq-card">
              <div class="rfq-header">
                <div>
                  <h4 class="mb-1">Industrial Pumps - Draft</h4>
                  <div class="rfq-meta">
                    <span><i class="bi bi-save"></i> Last saved: Today, 10:30 AM</span>
                  </div>
                </div>
                <div>
                  <span class="badge bg-secondary">Draft</span>
                </div>
              </div>

              <div class="rfq-details">
                <p class="rfq-description">
                  Need centrifugal pumps for water treatment facility...
                </p>

                <div class="d-flex gap-2">
                  <button class="btn btn-primary">
                    <i class="bi bi-pencil me-2"></i> Continue Editing
                  </button>
                  <button class="btn btn-outline-primary">
                    <i class="bi bi-eye me-2"></i> Preview
                  </button>
                  <button class="btn btn-outline-danger">
                    <i class="bi bi-trash me-2"></i> Delete Draft
                  </button>
                </div>
              </div>
            </div>
          </div>
          <%})%>
        </div>

        <!-- RFQ Statistics -->
        <div class="row mt-5">
          <div class="col-md-3">
            <div class="card-company text-center p-4">
              <i class="bi bi-megaphone display-4 text-primary mb-3"></i>
              <h3>12</h3>
              <p class="text-muted mb-0">Total RFQs Created</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card-company text-center p-4">
              <i class="bi bi-clock display-4 text-warning mb-3"></i>
              <h3>5</h3>
              <p class="text-muted mb-0">Avg. Bids per RFQ</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card-company text-center p-4">
              <i class="bi bi-currency-dollar display-4 text-success mb-3"></i>
              <h3>18%</h3>
              <p class="text-muted mb-0">Avg. Cost Savings</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card-company text-center p-4">
              <i class="bi bi-check-circle display-4 text-info mb-3"></i>
              <h3>92%</h3>
              <p class="text-muted mb-0">RFQ Success Rate</p>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light py-4 mt-5">
      <div class="container-fluid">
        <div class="row">
          <div class="col-md-6">
            <p class="mb-0">&copy; 2023 ProcurePro. All rights reserved.</p>
          </div>
          <div class="col-md-6 text-md-end">
            <a href="#" class="text-muted me-3">Help & Support</a>
            <a href="#" class="text-muted me-3">Privacy Policy</a>
            <a href="#" class="text-muted">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Company JS -->
    <script src="../assets/js/company.js"></script>
  </body>
</html>
